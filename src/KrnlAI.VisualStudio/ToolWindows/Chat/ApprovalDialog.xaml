<Window x:Class="KrnlAI.VisualStudio.ToolWindows.Chat.ApprovalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Approve Action" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource VsBrush.Window}"
        Foreground="{DynamicResource VsBrush.WindowText}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Action Required" FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />

    <Border Grid.Row="1" Padding="8" Margin="0,0,0,12"
            Background="#33FFA500" CornerRadius="6">
      <TextBlock x:Name="RiskLevelText" FontWeight="SemiBold" />
    </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="Action:" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock x:Name="ActionText" TextWrapping="Wrap" Margin="0,0,0,12" />

        <TextBlock Text="Details:" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="DetailsBox" IsReadOnly="True" TextWrapping="Wrap"
                 MinHeight="60" Padding="4" />
      </StackPanel>
    </ScrollViewer>

    <TextBlock Grid.Row="3" Text="Comment (optional):" FontWeight="Bold" Margin="0,8,0,4" />
    <TextBox x:Name="CommentBox" Grid.Row="3" Margin="0,24,0,8" Height="28" />

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button x:Name="RejectButton" Content="Reject" Width="80" Height="28" Margin="0,0,8,0" Click="OnReject" />
      <Button x:Name="ApproveButton" Content="Approve" Width="80" Height="28" Click="OnApprove"
              IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>
