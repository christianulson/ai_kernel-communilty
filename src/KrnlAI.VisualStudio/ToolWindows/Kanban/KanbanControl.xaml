<UserControl x:Class="KrnlAI.VisualStudio.ToolWindows.Kanban.KanbanControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource VsBrush.Window}"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Filters -->
        <Border Grid.Row="0" Margin="8,8,8,4" Padding="8" Background="{DynamicResource VsBrush.CommandBarOptionsBackground}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Days:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource VsBrush.CaptionText}"/>
                <ComboBox x:Name="DaysCombo" Width="60" Margin="0,0,16,0" SelectedIndex="2">
                    <ComboBoxItem Content="1"/><ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="7"/><ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="14"/><ComboBoxItem Content="30"/>
                </ComboBox>
                <TextBlock Text="Domain:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource VsBrush.CaptionText}"/>
                <TextBox x:Name="DomainBox" Width="100" Margin="0,0,16,0"/>
                <Button x:Name="RefreshButton" Content="Refresh" Width="80" Height="22"
                        Click="OnRefresh" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{DynamicResource VsBrush.GrayText}"/>
            </StackPanel>
        </Border>
        <!-- Columns -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" Margin="8">
            <ItemsControl x:Name="ColumnsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource VsBrush.ActiveBorder}"
                                BorderThickness="1" CornerRadius="4" Margin="0,0,8,0"
                                MinWidth="200" MaxWidth="260"
                                Background="{DynamicResource VsBrush.CommandBarOptionsBackground}">
                            <StackPanel>
                                <Grid Margin="8,8,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               FontWeight="Bold" FontSize="13"
                                               Foreground="{DynamicResource VsBrush.CaptionText}"/>
                                    <Border Grid.Column="1" CornerRadius="8" Padding="6,1"
                                            Background="{DynamicResource VsBrush.AccentKey}">
                                        <TextBlock Text="{Binding TotalCount}" FontSize="11"
                                                   Foreground="{DynamicResource VsBrush.WindowText}"/>
                                    </Border>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Cards}" Margin="8,0,8,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource VsBrush.ActiveBorder}"
                                                    BorderThickness="1" CornerRadius="4"
                                                    Padding="8" Margin="0,0,0,6"
                                                    Background="{DynamicResource VsBrush.Window}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Description}"
                                                                   TextWrapping="Wrap" MaxHeight="40"
                                                                   Foreground="{DynamicResource VsBrush.CaptionText}"/>
                                                        <Border Grid.Column="1" CornerRadius="3" Padding="4,1"
                                                                Background="{DynamicResource VsBrush.AccentKey}"
                                                                Margin="4,0,0,0">
                                                            <TextBlock Text="{Binding Priority, StringFormat='P{0}'}"
                                                                       FontSize="10" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                    <ProgressBar Value="{Binding Progress}" Maximum="1"
                                                                 Height="4" Margin="0,6,0,0"/>
                                                    <TextBlock Text="{Binding Deadline, StringFormat='📅 {0:yyyy-MM-dd}'}"
                                                               FontSize="10" Margin="0,2,0,0"
                                                               Foreground="{DynamicResource VsBrush.GrayText}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
