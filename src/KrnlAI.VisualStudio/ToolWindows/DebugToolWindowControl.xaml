<UserControl x:Class="KrnlAI.VisualStudio.ToolWindows.DebugToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600"
             Background="{DynamicResource VsBrush.Window}">
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="🧠 Debug Trace" FontSize="14" FontWeight="Bold"
                 Foreground="{DynamicResource VsBrush.CaptionText}" VerticalAlignment="Center" />
      <TextBlock Grid.Column="1" x:Name="CountText" Text="0 operations"
                 Foreground="{DynamicResource VsBrush.GrayText}" Margin="12,0,0,0" VerticalAlignment="Center" />
      <StackPanel Grid.Column="2" Orientation="Horizontal">
        <Button x:Name="ClearButton" Content="Clear" Width="60" Height="22" Click="OnClear" Margin="0,0,4,0" />
        <Button x:Name="RefreshButton" Content="Refresh" Width="60" Height="22" Click="OnRefresh" />
      </StackPanel>
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
      <ItemsControl x:Name="OperationList" BorderThickness="0" Focusable="False"
                    Foreground="{DynamicResource VsBrush.WindowText}" FontFamily="Consolas" FontSize="12" />
    </ScrollViewer>

    <TextBlock Grid.Row="2" x:Name="StatusText" Text="Ready"
               Foreground="{DynamicResource VsBrush.GrayText}" Margin="0,4,0,0" />
  </Grid>
</UserControl>
