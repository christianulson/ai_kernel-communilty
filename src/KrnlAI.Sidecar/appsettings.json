{
  "Sidecar": {
    "Mode": "Legacy",
    "Auth": {
      "Token": ""
    },
    "Otlp": {
      "Endpoint": "",
      "Headers": ""
    },
    "AgentRun": {
      "TimeoutSeconds": 120
    },
    "KernelApi": {
      "BaseUrl": "",
      "TimeoutSeconds": 10,
      "CacheTtlSeconds": 60,
      "RetryCount": 3,
      "CircuitBreakDurationSeconds": 15,
      "CircuitMinThroughput": 5
    },
    "RateLimiting": {
      "GlobalPermitLimit": 60,
      "WindowSeconds": 10,
      "AgentRunPermitLimit": 10,
      "MemoryReadPermitLimit": 30
    },
    "Cors": {
      "AllowedOrigins": []
    },
    "ApiVersion": {
      "Prefix": ""
    }
  },
  "Store": {
    "Mode": "SQLite",
    "SqliteMode": "Hybrid"
  },
  "Vector": {
    "Mode": "Sqlite"
  },
  "Cache": {
    "Mode": "Memory"
  },
  "Skills": {
    "StoreMode": "Document"
  },
  "LLM": {
    "Provider": "ollama"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "KrnlAI": "Information"
    }
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 1048576
    }
  }
}
