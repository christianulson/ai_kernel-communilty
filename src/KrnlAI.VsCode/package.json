{
  "name": "krnlai-vscode",
  "displayName": "Krnl-AI",
  "description": "Krnl-AI - Cognitive agent for VS Code with coding assistance, memory, safety, and adaptive planning",
  "version": "1.0.0",
  "publisher": "krnlai",
  "activationEvents": [
    "onCommand:krnlai.chat",
    "onCommand:krnlai.dashboard",
    "onCommand:krnlai.policies",
    "onCommand:krnlai.episodes",
    "onCommand:krnlai.memory",
    "onCommand:krnlai.settings",
    "onCommand:krnlai.start",
    "onCommand:krnlai.stop",
    "onStartupFinished"
  ],
  "license": "MIT",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other",
    "Machine Learning"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "icon": "icon.png",
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/krnl-ai/kernel.git"
  },
  "homepage": "https://krnl.ai",
  "bugs": {
    "url": "https://github.com/krnl-ai/kernel/issues"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "krnlai.start",
        "title": "Krnl-AI: Iniciar Sidecar"
      },
      {
        "command": "krnlai.stop",
        "title": "Krnl-AI: Parar Sidecar"
      },
      {
        "command": "krnlai.chat",
        "title": "Krnl-AI: Chat"
      },
      {
        "command": "krnlai.dashboard",
        "title": "Krnl-AI: Dashboard"
      },
      {
        "command": "krnlai.policies",
        "title": "Krnl-AI: Políticas"
      },
      {
        "command": "krnlai.episodes",
        "title": "Krnl-AI: Episódios"
      },
      {
        "command": "krnlai.memory",
        "title": "Krnl-AI: Memória"
      },
      {
        "command": "krnlai.settings",
        "title": "Krnl-AI: Configurações"
      },
      {
        "command": "krnlai.coding.chat",
        "title": "Krnl-AI: Chat com Contexto do Editor"
      },
      {
        "command": "krnlai.coding.explain",
        "title": "Krnl-AI: Explicar Código"
      },
      {
        "command": "krnlai.coding.fix",
        "title": "Krnl-AI: Corrigir Código"
      },
      {
        "command": "krnlai.coding.test",
        "title": "Krnl-AI: Gerar Teste"
      },
      {
        "command": "krnlai.coding.refactor",
        "title": "Krnl-AI: Refatorar Código"
      },
      {
        "command": "krnlai.coding.review",
        "title": "Krnl-AI: Revisar Código"
      },
      {
        "command": "krnlai.coding.run",
        "title": "Krnl-AI: Executar Prompt..."
      },
      {
        "command": "krnlai.acceptNextWord",
        "title": "Krnl-AI: Aceitar próxima palavra da sugestão"
      },
      {
        "command": "krnlai.debugTrace",
        "title": "Krnl-AI: Debug Trace (ver operações internas)"
      },
      {
        "command": "krnlai.debugBuild",
        "title": "Krnl-AI: Debug Build"
      },
      {
        "command": "krnlai.debugLaunch",
        "title": "Krnl-AI: Debug Launch"
      },
      {
        "command": "krnlai.debugStop",
        "title": "Krnl-AI: Debug Stop"
      },
      {
        "command": "krnlai.debugStepOver",
        "title": "Krnl-AI: Debug Step Over"
      },
      {
        "command": "krnlai.debugStepInto",
        "title": "Krnl-AI: Debug Step Into"
      },
      {
        "command": "krnlai.debugContinue",
        "title": "Krnl-AI: Debug Continue"
      },
      {
        "command": "krnlai.debugBreakpoint",
        "title": "Krnl-AI: Debug Breakpoint"
      },
      {
        "command": "krnlai.debugPanel",
        "title": "Krnl-AI: Debug Trace Panel"
      }
    ],
    "keybindings": [
      {
        "command": "krnlai.coding.explain",
        "key": "ctrl+shift+e",
        "when": "config.krnlai.codingAgent.enabled && editorTextFocus"
      },
      {
        "command": "krnlai.coding.fix",
        "key": "ctrl+shift+f",
        "when": "config.krnlai.codingAgent.enabled && editorTextFocus"
      },
      {
        "command": "krnlai.coding.test",
        "key": "ctrl+shift+t",
        "when": "config.krnlai.codingAgent.enabled && editorTextFocus"
      },
      {
        "command": "krnlai.coding.run",
        "key": "ctrl+shift+r",
        "when": "config.krnlai.codingAgent.enabled && editorTextFocus"
      },
      {
        "command": "krnlai.acceptNextWord",
        "key": "ctrl+right",
        "when": "config.krnlai.codingAgent.inlineCompletion && editorTextFocus"
      },
      {
        "command": "krnlai.debugLaunch",
        "key": "ctrl+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "krnlai.debugStepOver",
        "key": "f10",
        "when": "debugState == 'running'"
      },
      {
        "command": "krnlai.debugStepInto",
        "key": "f11",
        "when": "debugState == 'running'"
      },
      {
        "command": "krnlai.debugContinue",
        "key": "f5",
        "when": "debugState == 'running'"
      },
      {
        "command": "krnlai.debugStop",
        "key": "shift+f5",
        "when": "debugState == 'running'"
      },
      {
        "command": "krnlai.debugPanel",
        "key": "ctrl+shift+'",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "krnlai.start",
          "when": "view == krnlai.nav",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "krnlai.coding.explain",
          "group": "Krnl-AI",
          "when": "config.krnlai.codingAgent.enabled && editorHasSelection"
        },
        {
          "command": "krnlai.coding.fix",
          "group": "Krnl-AI",
          "when": "config.krnlai.codingAgent.enabled && editorHasSelection"
        },
        {
          "command": "krnlai.coding.test",
          "group": "Krnl-AI",
          "when": "config.krnlai.codingAgent.enabled && editorHasSelection"
        },
        {
          "command": "krnlai.coding.refactor",
          "group": "Krnl-AI",
          "when": "config.krnlai.codingAgent.enabled && editorHasSelection"
        }
      ],
      "editor/codeAction": [
        {
          "command": "krnlai.coding.fix",
          "group": "Krnl-AI",
          "when": "config.krnlai.codingAgent.enabled"
        },
        {
          "command": "krnlai.coding.explain",
          "group": "Krnl-AI",
          "when": "config.krnlai.codingAgent.enabled"
        },
        {
          "command": "krnlai.coding.test",
          "group": "Krnl-AI",
          "when": "config.krnlai.codingAgent.enabled"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "krnlai",
          "title": "Krnl-AI",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "krnlai": [
        {
          "id": "krnlai.nav",
          "name": "Navegação"
        }
      ]
    },
    "configuration": {
      "title": "Krnl-AI",
      "properties": {
        "krnlai.endpoint": {
          "type": "string",
          "default": "http://localhost:5235",
          "description": "Endpoint do backend Krnl-AI"
        },
        "krnlai.mode": {
          "type": "string",
          "default": "localApi",
          "enum": [
            "embedded",
            "localApi",
            "remoteApi"
          ],
          "description": "Modo de runtime: embedded via Sidecar, API local ou API remota"
        },
        "krnlai.standalone": {
          "type": "boolean",
          "default": false,
          "description": "Compatibilidade: usar Sidecar local em vez da API. Prefira krnlai.mode=embedded."
        },
        "krnlai.sidecarPort": {
          "type": "number",
          "default": 5001,
          "description": "Porta do Sidecar local"
        },
        "krnlai.sidecarPath": {
          "type": "string",
          "default": "",
          "description": "Caminho personalizado para o Sidecar .csproj ou .exe. Se vazio, usa o padrão do projeto."
        },
        "krnlai.sidecarTransport": {
          "type": "string",
          "default": "http",
          "enum": [
            "http",
            "stdio"
          ],
          "description": "Transporte do Sidecar local: http (HTTP REST) ou stdio (StreamJsonRpc sobre pipes)"
        },
        "krnlai.codingAgent.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar modo Coding Agent (comandos de código, chat com contexto do editor)"
        },
        "krnlai.codingAgent.inlineCompletion": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar autocomplete inline de código enquanto digita (requer codingAgent.enabled = true)"
        },
        "krnlai.codingAgent.terminal": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar execução de comandos no terminal (/run, /build, /test-cmd)"
        },
        "krnlai.codingAgent.git": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar comandos git (/commit, /diff, /branch, /status, /log, /review-pr)"
        },
        "krnlai.codingAgent.agenticLoops": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar loop agente multi-passo (/task). Requer terminal habilitado."
        },
        "krnlai.codingAgent.chatParticipant": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar ChatParticipant API nativa do VS Code (experimental, VS Code 1.82+)"
        },
        "krnlai.codingAgent.hover": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar explicações on-hover de código"
        }
      }
    }
  },
  "scripts": {
    "e2e": "node ./out/e2e/runner.js",
    "e2e:build": "tsc -p tsconfig.json --outDir out"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.118.0",
    "@vscode/test-electron": "^2.5.2",
    "jest": "^30.4.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
