{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Krnl-AI Desktop",
  "version": "0.1.0",
  "identifier": "com.krnlai.desktop",
  "build": {
    "frontendDist": "../../../webapp/apps/kernel-ui/dist",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "cd ../../../webapp && npx nx run @krnl-ai/kernel-ui:serve --configuration=local",
    "beforeBuildCommand": "cd ../../../webapp && npx nx run @krnl-ai/kernel-ui:build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Krnl-AI Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* ws: wss:; img-src 'self' data: blob:; media-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": [],
    "copyright": "Copyright (c) 2026 Krnl-AI Team",
    "category": "DeveloperTool",
    "shortDescription": "Krnl-AI Desktop - Cognitive agent client",
    "longDescription": "Cross-platform desktop client for the Krnl-AI cognitive agent. Features local sidecar execution, peer ranking, kanban board, and full system management.",
    "publisher": "Krnl-AI",
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "languages": ["en-US", "pt-BR"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": []
    }
  },
  "updater": {
    "active": true,
    "dialog": true,
    "pubkey": "",
    "endpoints": [
      "https://github.com/krnl-ai/kernel/releases/latest/download/updater.json"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["krnl-ai"]
      }
    }
  }
}
