{
  "name": "aikernel-vscode",
  "displayName": "AI Kernel",
  "description": "AI Kernel - Agente cognitivo no VsCode",
  "version": "1.0.0",
  "publisher": "aikernel",
  "license": "MIT",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:aikernel.start",
    "onCommand:aikernel.chat",
    "onCommand:aikernel.coding.chat",
    "onView:aikernel.nav"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aikernel.start",
        "title": "AI Kernel: Iniciar Sidecar"
      },
      {
        "command": "aikernel.stop",
        "title": "AI Kernel: Parar Sidecar"
      },
      {
        "command": "aikernel.chat",
        "title": "AI Kernel: Chat"
      },
      {
        "command": "aikernel.dashboard",
        "title": "AI Kernel: Dashboard"
      },
      {
        "command": "aikernel.policies",
        "title": "AI Kernel: Políticas"
      },
      {
        "command": "aikernel.episodes",
        "title": "AI Kernel: Episódios"
      },
      {
        "command": "aikernel.memory",
        "title": "AI Kernel: Memória"
      },
      {
        "command": "aikernel.settings",
        "title": "AI Kernel: Configurações"
      },
      {
        "command": "aikernel.coding.chat",
        "title": "AI Kernel: Chat com Contexto do Editor"
      },
      {
        "command": "aikernel.coding.explain",
        "title": "AI Kernel: Explicar Código"
      },
      {
        "command": "aikernel.coding.fix",
        "title": "AI Kernel: Corrigir Código"
      },
      {
        "command": "aikernel.coding.test",
        "title": "AI Kernel: Gerar Teste"
      },
      {
        "command": "aikernel.coding.refactor",
        "title": "AI Kernel: Refatorar Código"
      },
      {
        "command": "aikernel.coding.review",
        "title": "AI Kernel: Revisar Código"
      }
    ],
    "keybindings": [
      {
        "command": "aikernel.coding.explain",
        "key": "ctrl+shift+e",
        "when": "config.aikernel.codingAgent.enabled && editorTextFocus"
      },
      {
        "command": "aikernel.coding.fix",
        "key": "ctrl+shift+f",
        "when": "config.aikernel.codingAgent.enabled && editorTextFocus"
      },
      {
        "command": "aikernel.coding.test",
        "key": "ctrl+shift+t",
        "when": "config.aikernel.codingAgent.enabled && editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aikernel.start",
          "when": "view == aikernel.nav",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "aikernel.coding.explain",
          "group": "AI Kernel",
          "when": "config.aikernel.codingAgent.enabled && editorHasSelection"
        },
        {
          "command": "aikernel.coding.fix",
          "group": "AI Kernel",
          "when": "config.aikernel.codingAgent.enabled && editorHasSelection"
        },
        {
          "command": "aikernel.coding.test",
          "group": "AI Kernel",
          "when": "config.aikernel.codingAgent.enabled && editorHasSelection"
        },
        {
          "command": "aikernel.coding.refactor",
          "group": "AI Kernel",
          "when": "config.aikernel.codingAgent.enabled && editorHasSelection"
        }
      ],
      "editor/codeAction": [
        {
          "command": "aikernel.coding.fix",
          "group": "AI Kernel",
          "when": "config.aikernel.codingAgent.enabled"
        },
        {
          "command": "aikernel.coding.explain",
          "group": "AI Kernel",
          "when": "config.aikernel.codingAgent.enabled"
        },
        {
          "command": "aikernel.coding.test",
          "group": "AI Kernel",
          "when": "config.aikernel.codingAgent.enabled"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aikernel",
          "title": "AI Kernel",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "aikernel": [
        {
          "id": "aikernel.nav",
          "name": "Navegação"
        }
      ]
    },
    "configuration": {
      "title": "AI Kernel",
      "properties": {
        "aikernel.endpoint": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "Endpoint do backend AI Kernel"
        },
        "aikernel.standalone": {
          "type": "boolean",
          "default": false,
          "description": "Usar Sidecar local em vez da API remota"
        },
        "aikernel.sidecarPort": {
          "type": "number",
          "default": 5001,
          "description": "Porta do Sidecar local"
        },
        "aikernel.codingAgent.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar modo Coding Agent (comandos de código, chat com contexto do editor)"
        }
      }
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.118.0",
    "jest": "^30.4.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
