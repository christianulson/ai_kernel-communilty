{
  "name": "krnlai-vscode",
  "displayName": "AI Kernel",
  "description": "AI Kernel - Cognitive agent for VS Code with coding assistance, memory, safety, and adaptive planning",
  "version": "1.0.0",
  "publisher": "krnlai",
  "license": "MIT",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Development",
    "Machine Learning"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "icon": "icon.png",
  "pricing": "Free",
  "activationEvents": [
    "onCommand:krnlai.start",
    "onCommand:krnlai.chat",
    "onCommand:krnlai.coding.chat",
    "onView:krnlai.nav"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "krnlai.start",
        "title": "AI Kernel: Iniciar Sidecar"
      },
      {
        "command": "krnlai.stop",
        "title": "AI Kernel: Parar Sidecar"
      },
      {
        "command": "krnlai.chat",
        "title": "AI Kernel: Chat"
      },
      {
        "command": "krnlai.dashboard",
        "title": "AI Kernel: Dashboard"
      },
      {
        "command": "krnlai.policies",
        "title": "AI Kernel: Políticas"
      },
      {
        "command": "krnlai.episodes",
        "title": "AI Kernel: Episódios"
      },
      {
        "command": "krnlai.memory",
        "title": "AI Kernel: Memória"
      },
      {
        "command": "krnlai.settings",
        "title": "AI Kernel: Configurações"
      },
      {
        "command": "krnlai.coding.chat",
        "title": "AI Kernel: Chat com Contexto do Editor"
      },
      {
        "command": "krnlai.coding.explain",
        "title": "AI Kernel: Explicar Código"
      },
      {
        "command": "krnlai.coding.fix",
        "title": "AI Kernel: Corrigir Código"
      },
      {
        "command": "krnlai.coding.test",
        "title": "AI Kernel: Gerar Teste"
      },
      {
        "command": "krnlai.coding.refactor",
        "title": "AI Kernel: Refatorar Código"
      },
      {
        "command": "krnlai.coding.review",
        "title": "AI Kernel: Revisar Código"
      },
      {
        "command": "krnlai.coding.run",
        "title": "AI Kernel: Executar Prompt..."
      }
    ],
    "keybindings": [
      {
        "command": "krnlai.coding.explain",
        "key": "ctrl+shift+e",
        "when": "config.krnlai.codingAgent.enabled && editorTextFocus"
      },
      {
        "command": "krnlai.coding.fix",
        "key": "ctrl+shift+f",
        "when": "config.krnlai.codingAgent.enabled && editorTextFocus"
      },
      {
        "command": "krnlai.coding.test",
        "key": "ctrl+shift+t",
        "when": "config.krnlai.codingAgent.enabled && editorTextFocus"
      },
      {
        "command": "krnlai.coding.run",
        "key": "ctrl+shift+r",
        "when": "config.krnlai.codingAgent.enabled && editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "krnlai.start",
          "when": "view == krnlai.nav",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "krnlai.coding.explain",
          "group": "AI Kernel",
          "when": "config.krnlai.codingAgent.enabled && editorHasSelection"
        },
        {
          "command": "krnlai.coding.fix",
          "group": "AI Kernel",
          "when": "config.krnlai.codingAgent.enabled && editorHasSelection"
        },
        {
          "command": "krnlai.coding.test",
          "group": "AI Kernel",
          "when": "config.krnlai.codingAgent.enabled && editorHasSelection"
        },
        {
          "command": "krnlai.coding.refactor",
          "group": "AI Kernel",
          "when": "config.krnlai.codingAgent.enabled && editorHasSelection"
        }
      ],
      "editor/codeAction": [
        {
          "command": "krnlai.coding.fix",
          "group": "AI Kernel",
          "when": "config.krnlai.codingAgent.enabled"
        },
        {
          "command": "krnlai.coding.explain",
          "group": "AI Kernel",
          "when": "config.krnlai.codingAgent.enabled"
        },
        {
          "command": "krnlai.coding.test",
          "group": "AI Kernel",
          "when": "config.krnlai.codingAgent.enabled"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "krnlai",
          "title": "AI Kernel",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "krnlai": [
        {
          "id": "krnlai.nav",
          "name": "Navegação"
        }
      ]
    },
    "configuration": {
      "title": "AI Kernel",
      "properties": {
        "krnlai.endpoint": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "Endpoint do backend AI Kernel"
        },
        "krnlai.standalone": {
          "type": "boolean",
          "default": false,
          "description": "Usar Sidecar local em vez da API remota"
        },
        "krnlai.sidecarPort": {
          "type": "number",
          "default": 5001,
          "description": "Porta do Sidecar local"
        },
        "krnlai.codingAgent.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar modo Coding Agent (comandos de código, chat com contexto do editor)"
        },
        "krnlai.codingAgent.inlineCompletion": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar autocomplete inline de código enquanto digita (requer codingAgent.enabled = true)"
        },
        "krnlai.codingAgent.terminal": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar execução de comandos no terminal (/run, /build, /test-cmd)"
        },
        "krnlai.codingAgent.git": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar comandos git (/commit, /diff, /branch, /status, /log, /review-pr)"
        },
        "krnlai.codingAgent.agenticLoops": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar loop agente multi-passo (/task). Requer terminal habilitado."
        },
        "krnlai.codingAgent.chatParticipant": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar ChatParticipant API nativa do VS Code (experimental, VS Code 1.82+)"
        },
        "krnlai.codingAgent.hover": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar explicações on-hover de código"
        }
      }
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.118.0",
    "jest": "^30.4.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
