# AI Kernel Configuration
# Generated by `krnlai new agent --template coding-agent`

agent:
  name: {{AgentName}}
  safety_level: {{SafetyLevel}}
  llm_provider: {{LlmProvider}}
  memory_enabled: {{MemoryEnabled}}

cognitive_cycle:
  enabled: true
  steps:
    - sense
    - attend
    - reason
    - act
    - learn
  max_iterations: 10

safety:
  strict_mode: {{SafetyLevel}} == "strict"
  allowlist:
    - kernel.handle
