<Window x:Class="KrnlAI.Desktop.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters"
        mc:Ignorable="d"
        Title="{loc:Loc app_title}" Height="560" Width="480"
        MinHeight="520" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <Style TargetType="TextBox" x:Key="LoginTextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0E1727"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>
        <Style TargetType="PasswordBox" x:Key="LoginPasswordBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0E1727"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.3" RadiusX="0.7" RadiusY="0.7">
                <GradientStop Color="#0D1728" Offset="0"/>
                <GradientStop Color="#08111F" Offset="0.6"/>
                <GradientStop Color="#040A14" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>
        <Border Background="{StaticResource PanelBrush}" CornerRadius="24" Margin="36"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Opacity="0.4" ShadowDepth="0" Color="#030814"/>
            </Border.Effect>
            <StackPanel Margin="32,28" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Border Width="64" Height="64" CornerRadius="18" Background="#101A2C" BorderBrush="#4C38BDF8" BorderThickness="1">
                        <Border.Effect><DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="0" Color="#38BDF8"/></Border.Effect>
                        <Image Source="pack://application:,,,/KrnlAI.Desktop;component/Resources/Icons/krnl-ai-icon.png"
                               Width="52" Height="52" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <Border Padding="6,2" CornerRadius="999" Background="#1838BDF8" BorderBrush="#3C38BDF8" BorderThickness="1" Margin="0,0,0,4" HorizontalAlignment="Left">
                            <TextBlock Text="{loc:Loc login_brand_badge}" FontSize="9" FontWeight="Bold" Foreground="#BAE6FD"/>
                        </Border>
                        <TextBlock Text="{loc:Loc login_brand_tagline}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="{loc:Loc login_badge}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                <TextBlock Text="{loc:Loc login_title}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{loc:Loc login_subtitle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,24"/>
                <TextBlock Text="{loc:Loc login_username}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <Border Background="#B808111F" CornerRadius="17" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14,0" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="@" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="UsernameTextBox" Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource LoginTextBox}"/>
                    </Grid>
                </Border>
                <TextBlock Text="{loc:Loc login_password}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,6"/>
                <Border Background="#B808111F" CornerRadius="17" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14,0" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔒" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <PasswordBox x:Name="PasswordBox" Grid.Column="1" Style="{StaticResource LoginPasswordBox}">
                            <PasswordBox.InputBindings><KeyBinding Key="Return" Command="{Binding LoginCommand}"/></PasswordBox.InputBindings>
                        </PasswordBox>
                    </Grid>
                </Border>
                <CheckBox Content="{loc:Loc login_remember}" IsChecked="{Binding RememberMe}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0" FontSize="13"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,12,0,0"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Command="{Binding LoginCommand}" Height="48" Margin="0,20,0,0" IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Content" Value="{loc:Loc login_button}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Content" Value="{loc:Loc login_loading}"/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
