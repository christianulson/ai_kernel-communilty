<Window x:Class="KrnlAI.Desktop.App.MainWindow"        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"        xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"        xmlns:vm="clr-namespace:KrnlAI.Desktop.App.ViewModels"        xmlns:controls="clr-namespace:KrnlAI.Desktop.App.Controls"        mc:Ignorable="d"        Title="Krnl-AI Desktop" Height="800" Width="1200"        WindowStartupLocation="CenterScreen"        Background="{DynamicResource BackgroundBrush}"        MinHeight="600" MinWidth="900">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Effect>
        <DropShadowEffect BlurRadius="0"/>
    </Window.Effect>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- ═══════════════════════════ SIDEBAR ═══════════════════════════ -->
        <Border Grid.Column="0" Grid.RowSpan="2"                Background="#B808111F"                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Brand -->
                <Border Grid.Row="0" Padding="18,20,18,16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="16"                                Background="#2E38BDF8"                                BorderBrush="#4C38BDF8" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" Opacity="0.25" ShadowDepth="0" Color="#38BDF8"/>
                            </Border.Effect>
                            <TextBlock Text="⚡" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc sidebar_brand}" FontSize="14" FontWeight="Bold"                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{loc:Loc sidebar_subtitle}" FontSize="11"                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
        <!-- Update Banner -->
        <Border Grid.Row="0" Padding="18,0,18,4"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border CornerRadius="12" Padding="10,6" Background="#2EF59E0B">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run Text="🚀 Atualização disponível: "/><Run Text="{Binding UpdateVersion}" FontWeight="Bold"/></TextBlock>
                    <Button Grid.Column="1" Command="{Binding DownloadUpdateCommand}" Style="{StaticResource SmallButton}" Padding="8,4" FontSize="10" Content="Baixar"/>
                </Grid>
            </Border>
        </Border>
        <!-- Backend Status -->
        <Border Grid.Row="2" Margin="18,0,18,8" Padding="10,8"                        CornerRadius="999"                        Background="#12FFFFFF"                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="9" Height="9" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBackendAvailable}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Grid.Column="1" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="KrnlAI offline"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBackendAvailable}" Value="True">
                                            <Setter Property="Text" Value="KrnlAI online"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style></TextBlock>
                    </Grid>
                </Border>
                <!-- Agent Card -->
                <Border Grid.Row="2" Margin="18,0,18,12" Padding="14" CornerRadius="16"
                        Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc sidebar_agent_label}" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" CornerRadius="10"
                                    Background="#2E38BDF8" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedAgent.Name}" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="{Binding SelectedAgent.Name}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding SelectedAgent.Description}" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- Navigation Menu -->
                <StackPanel Grid.Row="3" Margin="12,8,12,0">
                    <TextBlock Text="{loc:Loc sidebar_nav_title}" FontSize="10" FontWeight="Bold"                               Foreground="{DynamicResource TextSecondaryBrush}"                               Margin="4,0,0,8"/>
                    <Button Command="{Binding NavigateToChatCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.Name="Chat"
                            AutomationProperties.AutomationId="ChatButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💬" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_chat}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToDashboardCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="DashboardButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_dashboard}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToPoliciesCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="PoliciesButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_policies}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToKanbanCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.Name="Kanban"
                            AutomationProperties.AutomationId="KanbanButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📌" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_kanban}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToEpisodesCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="EpisodesButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📜" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_episodes}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToMemoryCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="MemoryButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧠" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_memory}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToSettingsCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="SettingsButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_settings}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToApiKeysCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="ApiKeysButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔑" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_api_keys}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToPeerRankingCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.Name="PeerRanking"
                            AutomationProperties.AutomationId="PeerRankingButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏆" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_peer_ranking}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToBenchmarkCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="BenchmarkButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_benchmark}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToCausalCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="CausalButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_causal}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToProfileCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="ProfileButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_profile}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToPrivacyCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="PrivacyButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛡️" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_privacy}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToDocumentsCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="DocumentsButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_documents}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToArchiveCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="ArchiveButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_archive}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToModelRegistryCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="ModelRegistryButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧠" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_model_registry}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToVersionsCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="VersionsButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔖" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_versions}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToSessionsCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="SessionsButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_sessions}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToTrajectoryCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="TrajectoryButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_trajectories}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToP2PPaymentsCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="P2PPaymentsButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_p2p_payments}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToDisputesCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="DisputesButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚖️" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_disputes}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToMultimodalCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="MultimodalButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔬" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_multimodal}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToSidecarCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="SidecarButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖥️" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_sidecar}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToObjectivesCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="ObjectivesButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎯" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_objectives}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToInvestigationsCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="InvestigationsButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔎" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_investigations}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToSnapshotsCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="SnapshotsButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📸" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_snapshots}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToAdminConfigCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="AdminConfigButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_admin_config}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToAdminUsersCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="AdminUsersButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_admin_users}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToMomentsCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="MomentsButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧠" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_moments}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToPluginsCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="PluginsButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔌" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_plugins}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToSchedulerCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="SchedulerButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Loc nav_scheduler}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToTemplatesCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="TemplatesButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Templates"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToCliCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="CliButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💻" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="CLI"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToPluginCatalogCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="PluginCatalogButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧩" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Plugins"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateToExperimentCommand}" Style="{StaticResource NavButton}"                            Margin="0,0,0,2"
                            AutomationProperties.AutomationId="ExperimentButton">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧪" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Experimentos"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <!-- Sessions -->
                <Border Grid.Row="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"                        Padding="12,12,12,8">
                    <StackPanel>
                        <Grid Margin="4,0,4,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{loc:Loc sidebar_sessions_label}" FontSize="10" FontWeight="Bold"                                       Foreground="{DynamicResource TextSecondaryBrush}"                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Command="{Binding NewSessionCommand}"                                    Style="{StaticResource SmallButton}" Padding="8,4" FontSize="10"                                    Content="{loc:Loc sidebar_new_session}"/>
                        </Grid>

                        <TextBox Text="{Binding SessionFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" FontSize="11" Margin="0,0,0,4"
                                 ToolTip="Filtrar conversas"/>
                        <ListBox ItemsSource="{Binding FilteredSessions}" SelectedItem="{Binding ActiveSession}"                                 Background="Transparent" BorderThickness="0" MaxHeight="140">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" CornerRadius="12"                                            Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}"                                            BorderThickness="1" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" FontSize="12"                                                       Foreground="{DynamicResource TextPrimaryBrush}"                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="✎" Command="{Binding DataContext.RenameSessionCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"                                                        Style="{StaticResource SmallButton}" FontSize="9" Padding="4" Width="22" Height="22" Margin="0,0,2,0"/>
                                                <Button Content="✕" Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"                                                        Style="{StaticResource DangerSmallButton}" FontSize="9" Padding="4" Width="22" Height="22"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
                <!-- Theme Toggle + Logout -->
                <Border Grid.Row="5" Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Button Command="{Binding ToggleLogsCommand}"                                Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Logs" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding StartSidecarCommand}"                                Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Padding="12,8" Margin="0,2,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖥️" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Iniciar Sidecar" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ToggleThemeCommand}"                                Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ThemeIcon}" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ThemeLabel}" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding BackupCommand}"                                Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Padding="12,8" Margin="0,2,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Backup" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RestoreCommand}"                                Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Padding="12,8" Margin="0,2,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Restaurar" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding FeedbackCommand}"                                Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Padding="12,8" Margin="0,2,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💬" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Feedback" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding LogoutCommand}"                                Style="{StaticResource DangerButton}" HorizontalAlignment="Stretch" Padding="12,8" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="{loc:Loc sidebar_logout}" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <!-- ═══════════════════════════ MAIN CONTENT ═══════════════════════════ -->
        <Grid Grid.Column="1" Grid.Row="0">
            <controls:ChatControl Visibility="{Binding IsChatVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:DashboardControl Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:PoliciesControl Visibility="{Binding IsPoliciesVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:EpisodesControl Visibility="{Binding IsEpisodesVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:MemoryControl Visibility="{Binding IsMemoryVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:SettingsControl Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:BenchmarkControl Visibility="{Binding IsBenchmarkVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:KanbanControl DataContext="{Binding KanbanVM}" Visibility="{Binding DataContext.IsKanbanVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:CausalGraphControl Visibility="{Binding IsCausalVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:ProfileControl Visibility="{Binding IsProfileVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:ApiKeysControl Visibility="{Binding IsApiKeysVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:PeerRankingControl Visibility="{Binding IsPeerRankingVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:PrivacyControl Visibility="{Binding IsPrivacyVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:DocumentControl Visibility="{Binding IsDocumentsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:ArchiveControl Visibility="{Binding IsArchiveVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:ModelRegistryControl Visibility="{Binding IsModelRegistryVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:VersionsControl Visibility="{Binding IsVersionsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:SessionsControl Visibility="{Binding IsSessionsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:TrajectoryControl Visibility="{Binding IsTrajectoryVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:P2PPaymentsControl Visibility="{Binding IsP2PPaymentsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:DisputesControl Visibility="{Binding IsDisputesVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:SidecarConfigControl Visibility="{Binding IsSidecarVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:ObjectivesControl Visibility="{Binding IsObjectivesVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:InvestigationsControl Visibility="{Binding IsInvestigationsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:SnapshotsControl Visibility="{Binding IsSnapshotsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:MultimodalControl Visibility="{Binding IsMultimodalVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:AdminConfigControl Visibility="{Binding IsAdminConfigVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:AdminUsersControl Visibility="{Binding IsAdminUsersVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:MomentsControl Visibility="{Binding IsMomentsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:PluginsControl Visibility="{Binding IsPluginsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:SchedulerControl Visibility="{Binding IsSchedulerVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:TemplatesControl Visibility="{Binding IsTemplatesVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:CliControl Visibility="{Binding IsCliVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:PluginCatalogControl Visibility="{Binding IsPluginCatalogVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:ExperimentControl Visibility="{Binding IsExperimentVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <controls:LogsViewerControl Visibility="{Binding ShowLogs, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <!-- Welcome Wizard Overlay -->
            <Border Visibility="{Binding ShowWelcomeWizard, Converter={StaticResource BoolToVisibilityConverter}}"
                    Panel.ZIndex="200" Background="#CC000000">
                <controls:WelcomeWizardControl DataContext="{Binding WelcomeVM}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <!-- Video Call Overlay -->
            <Grid Visibility="{Binding IsInVideoCall, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="100">
                <Border Background="#CC000000"/>
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" Padding="24"                        HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="600" MinHeight="400"                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding VideoCallState}" Value="Connected">
                                                <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding VideoCallStateText}" FontSize="16" FontWeight="SemiBold"                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#1A1A1A" CornerRadius="12" Margin="8"                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <TextBlock Text="Local" Foreground="{DynamicResource TextSecondaryBrush}"                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Background="#1A1A1A" CornerRadius="12" Margin="8"                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <TextBlock Text="Remoto" Foreground="{DynamicResource TextSecondaryBrush}"                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Button Command="{Binding ToggleVideoCallMuteCommand}" Padding="16,12" Margin="6,0"                                    Style="{StaticResource GhostButton}">
                                <TextBlock Text="{Binding VideoCallMuteIcon}" FontSize="16"/>
                            </Button>
                            <Button Command="{Binding ToggleVideoCallCameraCommand}" Padding="16,12" Margin="6,0"                                    Style="{StaticResource GhostButton}">
                                <TextBlock Text="{Binding VideoCallCameraIcon}" FontSize="16"/>
                            </Button>
                            <Button Command="{Binding EndVideoCallCommand}" Padding="16,12" Margin="6,0"                                    Style="{StaticResource DangerButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📞" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Terminar"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            <!-- Search Overlay -->
            <controls:SearchOverlay x:Name="SearchOverlayCtrl" Visibility="{Binding ShowSearch, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <!-- Command Palette -->
            <Border Visibility="{Binding ShowCommandPalette, Converter={StaticResource BoolToVisibilityConverter}}"
                    Panel.ZIndex="300" Background="#CC000000">
                <Border Width="500" Height="Auto" Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="24" VerticalAlignment="Start" Margin="0,80,0,0">
                    <StackPanel>
                        <TextBox x:Name="CommandSearchBox" Height="44" FontSize="16"
                                 ToolTip="Digite o nome da tela..." KeyDown="OnCommandPaletteKeyDown"
                                 AutomationProperties.AutomationId="CommandPaletteSearchBox"/>
                        <ItemsControl x:Name="CommandPaletteResults" Margin="0,8,0,0" MaxHeight="400">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8" CornerRadius="8" Margin="0,2" Cursor="Hand"
                                            Background="{DynamicResource PanelSoftBrush}">
                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Border>
            <!-- Shortcuts Dialog -->
            <Border Visibility="{Binding ShowShortcuts, Converter={StaticResource BoolToVisibilityConverter}}"
                    Panel.ZIndex="300" Background="#CC000000">
                <Border Width="500" Height="Auto" Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="24" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Atalhos do Teclado" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="0" Padding="8,4" CornerRadius="6" Background="{DynamicResource PanelBrush}">
                                <TextBlock Text="Ctrl+Shift+K" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/></Border>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Iniciar/Parar escuta" Margin="12,0,0,8" VerticalAlignment="Center"/>
                            <Border Grid.Row="1" Padding="8,4" CornerRadius="6" Background="{DynamicResource PanelBrush}">
                                <TextBlock Text="Ctrl+Shift+T" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/></Border>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Sempre no topo" Margin="12,0,0,8" VerticalAlignment="Center"/>
                            <Border Grid.Row="2" Padding="8,4" CornerRadius="6" Background="{DynamicResource PanelBrush}">
                                <TextBlock Text="Ctrl+K" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/></Border>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Busca global" Margin="12,0,0,8" VerticalAlignment="Center"/>
                            <Border Grid.Row="3" Padding="8,4" CornerRadius="6" Background="{DynamicResource PanelBrush}">
                                <TextBlock Text="?" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/></Border>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Mostrar atalhos" Margin="12,0,0,8" VerticalAlignment="Center"/>
                        </Grid>
                        <Button Content="Fechar" Height="36" Width="100" Margin="0,16,0,0" HorizontalAlignment="Right"
                                Command="{Binding ToggleShortcutsCommand}"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
        <!-- ═══════════════════════════ STATUS BAR ═══════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="1"                Background="{DynamicResource PanelBrush}"                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Width="7" Height="7" Fill="{DynamicResource SuccessBrush}" Margin="0,0,8,0"                         VerticalAlignment="Center"/>
                <TextBlock Grid.Column="0" Text="{loc:Loc app_title}"                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"                           Margin="15,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding EmotionalMood}" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AccentBrush}" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ExecutiveModeIcon}" FontSize="11" Margin="120,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"                           VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Endpoint: {0}">
                            <Binding Path="ApiEndpoint"/>
                        </MultiBinding>
                    </TextBlock.Text></TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
