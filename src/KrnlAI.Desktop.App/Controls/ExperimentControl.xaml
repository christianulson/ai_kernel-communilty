<UserControl x:Class="KrnlAI.Desktop.App.Controls.ExperimentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <TextBlock Text="Sandbox de Experimentos" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Teste cenários sem afetar produção." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,18"/>
            <ItemsControl ItemsSource="{Binding ExperimentVM.Scenarios}">
                <ItemsControl.ItemTemplate><DataTemplate>
                    <Border Background="{DynamicResource PanelBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,6" Cursor="Hand">
                        <TextBlock Text="{Binding}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                </DataTemplate></ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Command="{Binding ExperimentVM.RunCommand}" Style="{StaticResource PrimaryButton}" Height="36" Width="200" Margin="0,12,0,0" Content="▶ Executar"/>
            <TextBlock Text="{Binding ExperimentVM.Status}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
