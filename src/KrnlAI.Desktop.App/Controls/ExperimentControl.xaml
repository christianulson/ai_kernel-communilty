<UserControl x:Class="KrnlAI.Desktop.App.Controls.ExperimentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="🧪 Experimentos" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Gerencie experimentos, métricas e análises." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding ExperimentsVM.LoadExperimentsCommand}" Style="{StaticResource GhostButton}" Padding="12,8">Atualizar</Button>
            </Grid>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding ExperimentsVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ExperimentsVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                    <Button Grid.Column="1" Command="{Binding ExperimentsVM.ClearErrorCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Novo Experimento" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBox Text="{Binding ExperimentsVM.NewExperimentName}" Height="36" FontSize="13" Margin="0,0,0,8" ToolTip="Nome do experimento"/>
                    <TextBox Text="{Binding ExperimentsVM.NewExperimentDescription}" Height="36" FontSize="13" Margin="0,0,0,8" ToolTip="Descrição"/>
                    <Button Command="{Binding ExperimentsVM.StartExperimentCommand}" Style="{StaticResource PrimaryButton}" Height="36" Width="140"
                            IsEnabled="{Binding ExperimentsVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">▶ Iniciar</Button>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding ExperimentsVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,20">
                    <TextBlock Text="⏳" FontSize="18" Margin="0,0,12,0"/>
                    <TextBlock Text="Carregando..." Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Experimentos" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding ExperimentsVM.Experiments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14" CornerRadius="16" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                                                <Border Padding="4,2" CornerRadius="6" Background="#1838BDF8">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1838BDF8"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="completed">
                                                                    <Setter Property="Background" Value="#1822C55E"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="failed">
                                                                    <Setter Property="Background" Value="#18FB7185"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:g}}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="📊 Análise" Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                                Command="{Binding DataContext.ExperimentsVM.ViewAnalysisCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding Id}" Style="{StaticResource SmallButton}"/>
                                        <Button Grid.Column="2" Content="✓ Concluir" Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                                Command="{Binding DataContext.ExperimentsVM.CompleteExperimentCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding Id}" Style="{StaticResource SmallButton}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20"
                    Visibility="{Binding ExperimentsVM.CurrentAnalysis, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📊 Análise" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Button Grid.Column="1" Command="{Binding ExperimentsVM.ClearAnalysisCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Padding="12" CornerRadius="12" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock Text="{Binding ExperimentsVM.CurrentAnalysis.TotalMetrics}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Métricas" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Padding="12" CornerRadius="12" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="{Binding ExperimentsVM.CurrentAnalysis.AvgValue, StringFormat={}{0:P1}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Média" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Padding="12" CornerRadius="12" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="{Binding ExperimentsVM.CurrentAnalysis.SuccessRate, StringFormat={}{0:P1}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Sucesso" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Padding="12" CornerRadius="12" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="4,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding ExperimentsVM.CurrentAnalysis.AvgLatencyMs, StringFormat={}{0:N0}ms}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Latência" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <TextBlock Text="Insights" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,4"/>
                    <ItemsControl ItemsSource="{Binding ExperimentsVM.CurrentAnalysis.Insights}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Histórico de Métricas" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,4"/>
                    <ItemsControl ItemsSource="{Binding ExperimentsVM.CurrentAnalysis.Metrics}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" CornerRadius="8" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Value, StringFormat={}{0:N4}}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat={}{0:g}}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
