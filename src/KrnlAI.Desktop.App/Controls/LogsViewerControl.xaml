<UserControl x:Class="KrnlAI.Desktop.App.Controls.LogsViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <TextBlock Text="Logs" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Visualização dos logs do aplicativo." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,18"/>
            <Border Background="#0A000000" CornerRadius="12" Padding="16" MinHeight="300" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <TextBlock x:Name="LogsText" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
            <Button x:Name="RefreshBtn" Content="⟳ Recarregar" Height="32" Width="120" Margin="0,8,0,0" Click="OnRefresh" Style="{StaticResource GhostButton}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
