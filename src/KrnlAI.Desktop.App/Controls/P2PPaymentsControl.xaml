<UserControl x:Class="KrnlAI.Desktop.App.Controls.P2PPaymentsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1240">
            <TextBlock Text="Pagamentos P2P" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Saldo, receipts e configuração de pagamentos da rede P2P."
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,18"/>

            <!-- Balance Card -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Recebido" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding P2PVM.EarnedFormatted}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Gasto" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding P2PVM.SpentFormatted}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource ErrorBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Pendente" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding P2PVM.PendingFormatted}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Orientation="Horizontal">
                        <Button Content="Atualizar" Height="36" Margin="0,0,8,0"
                                Command="{Binding P2PVM.RefreshCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Payment Mode -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Modo de pagamento" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding P2PVM.ModeDescription}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding P2PVM.AvailableModes}"
                              SelectedItem="{Binding P2PVM.SelectedMode}"
                              Width="180" Height="36" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Receipts -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Receipts" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding P2PVM.Receipts}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Height="240" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Work ID" Binding="{Binding WorkId}" Width="200"/>
                            <DataGridTextColumn Header="Worker" Binding="{Binding WorkerNodeId}" Width="120"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="100"/>
                            <DataGridTextColumn Header="Valor" Binding="{Binding PriceCents, StringFormat={}{0:F2}¢}" Width="90"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Success}" Width="80"/>
                            <DataGridTextColumn Header="Data" Binding="{Binding ExecutedAt, StringFormat=dd/MM HH:mm}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Batches -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Batches" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding P2PVM.PendingReceiptCount, StringFormat=Receipts pendentes: {0}}"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding P2PVM.Batches}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Height="160" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Batch ID" Binding="{Binding BatchId}" Width="240"/>
                            <DataGridTextColumn Header="Itens" Binding="{Binding Receipts.Count}" Width="80"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalCents, StringFormat={}{0:F2}¢}" Width="100"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Criado em" Binding="{Binding CreatedAt, StringFormat=dd/MM HH:mm}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
