<UserControl x:Class="KrnlAI.Desktop.App.Controls.StageRailControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ItemsControl x:Name="StageList">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Margin="4,0" Padding="12,6" CornerRadius="8" BorderThickness="1"
                        BorderBrush="{Binding BorderBrush}"
                        Background="{Binding Background}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Detail}" FontSize="10" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
