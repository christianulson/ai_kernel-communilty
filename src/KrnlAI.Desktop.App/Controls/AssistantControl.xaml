<UserControl x:Class="KrnlAI.Desktop.App.Controls.AssistantControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#B808111F" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="16">
            <StackPanel>
                <TextBlock Text="🧠 Assistant" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Button Command="{Binding AssistantVM.CreateThreadCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,12">Nova Thread</Button>
                <ItemsControl ItemsSource="{Binding AssistantVM.Threads}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" CornerRadius="12" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,4" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.AssistantVM.LoadThreadsCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                                </Border.InputBindings>
                                <TextBlock Text="{Binding Title}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                            Visibility="{Binding AssistantVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding AssistantVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                            <Button Grid.Column="1" Command="{Binding AssistantVM.ClearErrorCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                        </Grid>
                    </Border>
                    <ItemsControl ItemsSource="{Binding AssistantVM.Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14" CornerRadius="16" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Role}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:HH:mm}}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Content}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding AssistantVM.Content, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="13"
                             ToolTip="Digite sua mensagem...">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AssistantVM.SendMessageCommand}" CommandParameter="{Binding AssistantVM.Content}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Command="{Binding AssistantVM.SendMessageCommand}" CommandParameter="{Binding AssistantVM.Content}" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Height="40" MinWidth="80"
                            IsEnabled="{Binding AssistantVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">Enviar</Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
