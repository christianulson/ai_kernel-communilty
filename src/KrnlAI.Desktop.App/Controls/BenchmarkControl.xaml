<UserControl x:Class="KrnlAI.Desktop.App.Controls.BenchmarkControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{loc:Loc nav_benchmark}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Score, suítes e latência do sistema." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding BenchmarkVM.LoadCommand}" Style="{StaticResource GhostButton}" Padding="16,10">Atualizar</Button>
            </Grid>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding BenchmarkVM.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding BenchmarkVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
            </Border>

            <Border Background="{StaticResource PanelBrush}" CornerRadius="24" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="24" Margin="0,0,0,16"
                    Visibility="{Binding BenchmarkVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,20">
                    <TextBlock Text="⏳" FontSize="18" Margin="0,0,12,0"/>
                    <TextBlock Text="Carregando benchmark..." Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Margin="4">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding BenchmarkVM.Data.OverallScore, StringFormat={}{0:P1}}" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc benchmark_score}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="4">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding BenchmarkVM.Data.TotalSuites}" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Suítes" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{StaticResource PanelBrush}" CornerRadius="24" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Médias Globais" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding BenchmarkVM.Data.AvgLatencyMs, StringFormat={}{0:N0}ms}" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc dashboard_metrics_latency}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding BenchmarkVM.Data.AvgSuccessRate, StringFormat={}{0:P1}}" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc benchmark_avg_success}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource PanelBrush}" CornerRadius="24" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel>
                    <TextBlock Text="{loc:Loc benchmark_suites}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding BenchmarkVM.Data.Suites}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,10" CornerRadius="12" Background="#14FFFFFF" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="60"/><ColumnDefinition Width="80"/><ColumnDefinition Width="80"/><ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Scenarios}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Score, StringFormat={}{0:P1}}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding LatencyMs, StringFormat={}{0:N0}ms}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding SuccessRate, StringFormat={}{0:P1}}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
