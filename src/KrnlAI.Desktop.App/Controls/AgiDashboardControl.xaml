<UserControl x:Class="KrnlAI.Desktop.App.Controls.AgiDashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="AGI Dashboard" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AgiVM.Status}" Value="Carregado">
                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="Métricas internas do cérebro AGI."
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding AgiVM.LoadAgiDashboardCommand}"
                        Style="{StaticResource GhostButton}" Padding="20,10"
                        IsEnabled="{Binding AgiVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↻" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Atualizar" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Loading -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,20"
                    Visibility="{Binding AgiVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,20">
                    <TextBlock Text="⏳" FontSize="18" Margin="0,0,12,0"/>
                    <TextBlock Text="Carregando AGI..." Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Error -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,20"
                    Visibility="{Binding AgiVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌" FontSize="16" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding AgiVM.ErrorMessage}" Foreground="{DynamicResource ErrorBrush}"/>
                </StackPanel>
            </Border>

            <!-- 1. World Model Section -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🌍 World Model" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Erro de Predição" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding AgiVM.WorldModelError, StringFormat={}{0:P2}}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Latent Size" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding AgiVM.LatentSize, StringFormat={}{0:N0}}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ações Planejadas" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding AgiVM.NumActions, StringFormat={}{0:N0}}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 2. Learning Pipeline -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📚 Learning Pipeline" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Experiências" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding AgiVM.LearningExperiences, StringFormat={}{0:N0}}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Erro Antes" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding AgiVM.LearningErrorBefore, StringFormat={}{0:P2}}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource WarningBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Erro Depois" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding AgiVM.LearningErrorAfter, StringFormat={}{0:P2}}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 3. Goals & Causal Graph -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="24" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="🎯 Goals Ativos" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding AgiVM.ActiveGoals, StringFormat={}{0:N0}}" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="24" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🔗 Grafo Causal" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,24,0">
                                <TextBlock Text="Nós" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding AgiVM.CausalNodes, StringFormat={}{0:N0}}" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Arestas" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding AgiVM.CausalEdges, StringFormat={}{0:N0}}" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 4. Dream & Meta -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="24" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="💭 Dream" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding AgiVM.DreamSteps, StringFormat={}{0:N0} passos}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="24" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🧪 Meta-Learning" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,24,0">
                                <TextBlock Text="LR" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding AgiVM.MetaLearningRate, StringFormat={}{0:F4}}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Batch" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding AgiVM.MetaBatchSize, StringFormat={}{0:N0}}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 5. Multimodal -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🔬 Multimodal" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="12" Padding="14,10" Margin="0,0,12,0"
                                Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📷" FontSize="14" Margin="0,0,8,0"/>
                                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AgiVM.VisionAvailable}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Visão" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="12" Padding="14,10"
                                Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎤" FontSize="14" Margin="0,0,8,0"/>
                                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AgiVM.AudioAvailable}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Áudio" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 6. Behavior -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🧠 Comportamento" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Erro:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,12,8"/>
                        <TextBlock Grid.Column="1" Text="{Binding AgiVM.BehaviorError, StringFormat={}{0:P2}}" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Text="Descrição:" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AgiVM.BehaviorDescription}" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
