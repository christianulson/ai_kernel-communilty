<UserControl x:Class="KrnlAI.Desktop.App.Controls.FeedbackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="💬 Feedback" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Compartilhe sua opinião sobre o sistema." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,20"/>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding FeedbackVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding FeedbackVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                    <Button Grid.Column="1" Command="{Binding FeedbackVM.ClearErrorCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Enviar Feedback" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="Avaliação" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Command="{Binding FeedbackVM.SetRating1Command}" Style="{StaticResource GhostButton}" Padding="8,4" Margin="0,0,4,0">
                            <TextBlock Text="1 ⭐" FontSize="13"/></Button>
                        <Button Command="{Binding FeedbackVM.SetRating2Command}" Style="{StaticResource GhostButton}" Padding="8,4" Margin="0,0,4,0">
                            <TextBlock Text="2 ⭐" FontSize="13"/></Button>
                        <Button Command="{Binding FeedbackVM.SetRating3Command}" Style="{StaticResource GhostButton}" Padding="8,4" Margin="0,0,4,0">
                            <TextBlock Text="3 ⭐" FontSize="13"/></Button>
                        <Button Command="{Binding FeedbackVM.SetRating4Command}" Style="{StaticResource GhostButton}" Padding="8,4" Margin="0,0,4,0">
                            <TextBlock Text="4 ⭐" FontSize="13"/></Button>
                        <Button Command="{Binding FeedbackVM.SetRating5Command}" Style="{StaticResource GhostButton}" Padding="8,4">
                            <TextBlock Text="5 ⭐" FontSize="13"/></Button>
                    </StackPanel>
                    <TextBox Text="{Binding FeedbackVM.Comment, UpdateSourceTrigger=PropertyChanged}" Height="80" FontSize="13"
                             AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,8" ToolTip="Seu comentário..."/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding FeedbackVM.Category, UpdateSourceTrigger=PropertyChanged}" Height="36" FontSize="13" ToolTip="Categoria (opcional)"/>
                        <Button Grid.Column="1" Command="{Binding FeedbackVM.SubmitCommand}" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Height="36" MinWidth="100"
                                IsEnabled="{Binding FeedbackVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">Enviar</Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Histórico" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Command="{Binding FeedbackVM.LoadHistoryCommand}" Style="{StaticResource GhostButton}" Padding="12,8">Atualizar</Button>
            </Grid>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding FeedbackVM.Average, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Média Geral" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">
                            <TextBlock.Text>
                                <Binding Path="FeedbackVM.Average.AverageRating" StringFormat="{}{0:N1}"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="8,0,0,6">
                            <TextBlock.Text>
                                <Binding Path="FeedbackVM.Average.TotalFeedbacks" StringFormat="{}{0} avaliações"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding FeedbackVM.History}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14" CornerRadius="16" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PanelSoftBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Rating, StringFormat={}{0}}" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">
                                            <TextBlock.Text>
                                                <Binding Path="Rating" StringFormat="{}{0} ⭐"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0">
                                            <TextBlock.Text>
                                                <Binding Path="Category" StringFormat=" · {0}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Comment}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0">
                                        <TextBlock.Text>
                                            <Binding Path="CreatedAt" StringFormat="{}{0:g}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
