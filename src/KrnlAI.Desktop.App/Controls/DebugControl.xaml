<UserControl x:Class="KrnlAI.Desktop.App.Controls.DebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <TextBlock Text="🔧 Diagnóstico" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Verifique o estado do sistema." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,18"/>

            <Button Command="{Binding DebugVM.RunDiagnosticsCommand}" Style="{StaticResource PrimaryButton}" Height="40" Width="200" Content="▶ Executar Diagnóstico"/>
            <TextBlock Text="{Binding DebugVM.Status}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0"/>

            <ItemsControl ItemsSource="{Binding DebugVM.Diagnostics}" Margin="0,16,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,0,4"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <TextBlock Text="{Binding}" FontFamily="{StaticResource FontMono}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
