<UserControl x:Class="KrnlAI.Desktop.App.Controls.ChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters"
             xmlns:controls="clr-namespace:KrnlAI.Desktop.App.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding ActiveSession.Title, FallbackValue='Nova Conversa'}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Ellipse Width="8" Height="8" Fill="{Binding EmotionalTone, Converter={StaticResource MoodToColorConverter}}" Margin="16,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding EmotionalMood}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,0"/>
                        <Ellipse Width="8" Height="8" Margin="8,0,4,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAgentProcessing}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="processando..." FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                   Visibility="{Binding IsAgentProcessing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding ChatVM.ShareConversationCommand}" Style="{StaticResource GhostButton}" Padding="12,8" Margin="0,0,4,0"
                            ToolTip="Copiar conversa">
                        <TextBlock Text="🔗" FontSize="14"/>
                    </Button>
                    <Button Command="{Binding ChatVM.ExportConversationCommand}" Style="{StaticResource GhostButton}" Padding="12,8" Margin="0,0,4,0"
                            ToolTip="Exportar conversa">
                        <TextBlock Text="📥" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stage Rail -->
        <Border Grid.Row="1" Padding="16,8" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Visibility="{Binding ChatVM.IsCognitiveStreamVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <controls:StageRailControl x:Name="StageRail"/>
        </Border>

        <!-- Messages -->
        <ScrollViewer Grid.Row="2" Padding="28,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
            <TextBox Text="{Binding ChatVM.SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Height="32" FontSize="12" Margin="0,0,0,8"
                     ToolTip="Buscar na conversa (Ctrl+F)"
                     AutomationProperties.AutomationId="ChatSearchBox"/>
            <ItemsControl ItemsSource="{Binding ChatVM.Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Padding="16" CornerRadius="18"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Role}" Value="User">
                                            <Setter Property="Background" Value="#2938BDF8"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                            <Setter Property="Background" Value="#2E14B8A6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel MaxWidth="720">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#x1f464;  Usuário"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                        <Setter Property="Text" Value="&#x1f916;  Krnl-AI"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,0"/>
                                    <Button Command="{Binding DataContext.ChatVM.EditMessageCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding Id}" Style="{StaticResource SmallButton}" Padding="4" FontSize="9"
                                            Margin="8,0,2,0" Content="✎" ToolTip="Editar" Visibility="Collapsed"/>
                                    <Button Command="{Binding DataContext.ChatVM.DeleteMessageCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding Id}" Style="{StaticResource DangerSmallButton}" Padding="4" FontSize="9"
                                            Content="✕" ToolTip="Deletar" Visibility="Collapsed"/>
                                </StackPanel>
                                <Border MaxWidth="480" MaxHeight="360" CornerRadius="8" Margin="0,0,0,8" ClipToBounds="True"
                                        Visibility="{Binding ImageBase64, Converter={StaticResource StringToVisibilityConverter}}">
                                    <Image Source="{Binding ImageBase64, Converter={StaticResource Base64ToImageConverter}}"
                                           Cursor="Hand" MouseDown="OnImageClick"/>
                                </Border>
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPrimaryBrush}" LineHeight="26"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
        </ScrollViewer>

        <!-- Cognitive Step Timeline -->
        <Border Grid.Row="3" Padding="16,8" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Visibility="{Binding ChatVM.IsCognitiveStreamVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                MaxHeight="200">
            <controls:StepTimelineControl x:Name="StepTimeline"/>
        </Border>

        <!-- Voice Level Indicator -->
        <Border Grid.Row="4" Padding="28,6" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{loc:Loc chat_voice}" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Border Grid.Column="1" Height="8" CornerRadius="999" Background="#12FFFFFF" Margin="8,0">
                    <Border CornerRadius="999" Background="{DynamicResource AccentBrush}"
                            HorizontalAlignment="Left" Width="{Binding VoiceLevel, Converter={StaticResource PercentToWidthConverter}}"/>
                </Border>
                <TextBlock Grid.Column="2" Text="{Binding VoiceLevel, StringFormat={}{0:P0}}"
                           FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>
        </Border>

        <!-- Camera Preview -->
        <Border Grid.Row="5" Padding="16" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Visibility="{Binding ChatVM.IsCameraOn, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="240" Height="180" CornerRadius="8" BorderThickness="1"
                        BorderBrush="{DynamicResource BorderBrush}" Background="#0A000000">
                    <Image Source="{Binding ChatVM.CameraPreviewSource}" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Button Command="{Binding ChatVM.SnapCameraCommand}" Style="{StaticResource PrimaryButton}" MinWidth="100" Height="40"
                            Content="{loc:Loc chat_send_with_image}"/>
                    <Button Command="{Binding ChatVM.DismissCameraPreviewCommand}" Style="{StaticResource GhostButton}" MinWidth="80" Height="40"
                            Margin="8,0,0,0" Content="{loc:Loc cancel}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Composer -->
        <Border Grid.Row="6" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding ChatVM.MentionSuggestions}"
                             Visibility="{Binding ChatVM.IsMentionSuggestionsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                             SelectedIndex="{Binding ChatVM.MentionSelectedIndex}"
                             MaxHeight="120"
                             Margin="0,0,0,2"
                             Background="{DynamicResource PanelBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             FontSize="12">
                    </ListBox>
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding ChatVM.SlashSuggestions}"
                             Visibility="{Binding ChatVM.IsSlashSuggestionsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                             SelectedIndex="{Binding ChatVM.SlashSelectedIndex}"
                             MaxHeight="160"
                             Margin="0,0,0,4"
                             Background="{DynamicResource PanelBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Command}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBox Grid.Row="1" x:Name="ChatInput"
                             Text="{Binding ChatVM.InputText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="48" MaxHeight="200"
                             FontSize="14" VerticalScrollBarVisibility="Auto"
                             KeyDown="OnChatInputKeyDown">
                    </TextBox>
                </Grid>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Command="{Binding ChatVM.ToggleAudioCaptureCommand}" Style="{StaticResource GhostButton}" Width="48" Height="48" ToolTip="{Binding ChatVM.AudioButtonTooltip}">
                        <TextBlock Text="{Binding ChatVM.AudioButtonIcon}" FontSize="18"/>
                    </Button>
                    <Button Command="{Binding ChatVM.ToggleCameraCommand}" Style="{StaticResource GhostButton}" Width="48" Height="48" Margin="4,0,0,0">
                        <TextBlock Text="{Binding ChatVM.CameraButtonIcon}" FontSize="18"/>
                    </Button>
                    <Button Command="{Binding ChatVM.ToggleTtsCommand}" Style="{StaticResource GhostButton}" Width="48" Height="48" Margin="4,0,0,0"
                            ToolTip="Toggle text-to-speech">
                        <TextBlock Text="{Binding ChatVM.TtsIcon}" FontSize="18"/>
                    </Button>
                    <Button Command="{Binding ChatVM.SendMessageCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Height="48" MinWidth="100" Content="{loc:Loc chat_send}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
