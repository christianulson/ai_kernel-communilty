<UserControl x:Class="KrnlAI.Desktop.App.Controls.EpisodesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Main list -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{loc:Loc nav_episodes}" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Histórico de execuções do agente."
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding EpisodesVM.LoadEpisodesCommand}"
                            Style="{StaticResource GhostButton}" Padding="16,10"
                            IsEnabled="{Binding EpisodesVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">
                        <TextBlock Text="{Binding EpisodesVM.IsLoading, Converter={StaticResource BoolToStatusConverter}}"/>
                    </Button>
                </Grid>

                <!-- P7: Error Banner -->
                <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                        Visibility="{Binding EpisodesVM.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding EpisodesVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                </Border>

                <!-- Loading -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="24" Margin="0,0,0,16"
                        Visibility="{Binding EpisodesVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,20">
                        <TextBlock Text="⏳" FontSize="18" Margin="0,0,12,0"/>
                        <TextBlock Text="Carregando episódios..." Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24"
                        Visibility="{Binding EpisodesVM.HasNoData, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center"/>
                        <TextBlock Text="Nenhum episódio encontrado" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Execute comandos para gerar episódios." FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Episodes List -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="0">
                    <StackPanel>
                        <!-- Table header -->
                        <Grid Margin="20,16,20,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Status" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="Domínio" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="Objetivo" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="Resumo" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="Data" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding EpisodesVM.EpisodeList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="20,8" Margin="0,0,0,2"
                                            Background="Transparent" CornerRadius="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Padding="6,2" CornerRadius="6" BorderThickness="0" VerticalAlignment="Center" HorizontalAlignment="Left" Background="{Binding Status, Converter={StaticResource StatusToColorConverter}, ConverterParameter=bg}" Opacity="0.15">
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding GoalId}" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Outcome}" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Status}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                            <TextBlock Grid.Column="4" Text="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24"
                    Visibility="{Binding EpisodesVM.EpisodeDetail, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc episodes_detail}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Button Grid.Column="1" Content="✕" Style="{StaticResource SmallButton}" Command="{Binding EpisodesVM.ClearDetailCommand}" Width="28" Height="28"/>
                    </Grid>

                    <StackPanel>
                        <TextBlock Text="ID" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding EpisodesVM.EpisodeDetail.Id}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <TextBlock Text="Status" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding EpisodesVM.EpisodeDetail.Status}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <TextBlock Text="Goal ID" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding EpisodesVM.EpisodeDetail.GoalId}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <TextBlock Text="Resumo" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding EpisodesVM.EpisodeDetail.Summary}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <TextBlock Text="Criado em" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding EpisodesVM.EpisodeDetail.CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <TextBlock Text="Concluído em" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding EpisodesVM.EpisodeDetail.FinishedAt, TargetNullValue=—, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
