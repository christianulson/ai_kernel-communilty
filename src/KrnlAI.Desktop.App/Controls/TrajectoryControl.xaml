<UserControl x:Class="KrnlAI.Desktop.App.Controls.TrajectoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Trajectories" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Command="{Binding TrajectoryVM.RefreshCommand}"
                                Style="{StaticResource GhostButton}" Padding="10,6">
                            <TextBlock Text="⟳"/>
                        </Button>
                    </Grid>
                    <TextBox Grid.Row="1" Text="{Binding TrajectoryVM.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" Padding="6" FontSize="12">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding TrajectoryVM.RefreshCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <ListBox Grid.Row="1" x:Name="SessionList" ItemsSource="{Binding TrajectoryVM.Sessions}"
                             DisplayMemberPath="DisplayText"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="OnSessionDoubleClick"
                             Background="Transparent" BorderThickness="0"/>
                    <TextBlock Grid.Row="1" Text="No sessions"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.4"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Main -->
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="{Binding TrajectoryVM.SelectedSession.Prompt}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16"
                        Visibility="{Binding TrajectoryVM.HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TabControl SelectedIndex="{Binding TrajectoryVM.SelectedTabIndex}"
                                Background="Transparent" BorderThickness="0">
                        <TabItem Header="Steps" Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding TrajectoryVM.SelectedSession.Steps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,2" Padding="8" CornerRadius="8"
                                                    Background="#14FFFFFF"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Sequence, StringFormat='#{0}'}"
                                                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Action}" FontWeight="SemiBold" FontSize="12"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Stage}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        <TextBlock Text="{Binding Error}" FontSize="11" Foreground="#FFDBE1"
                                                                   Visibility="{Binding Error, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding DurationMs, StringFormat={}{0}ms}" FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        <TextBlock Text="{Binding TokensUsed, StringFormat={}{0} tokens}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Events" Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}">
                            <Grid>
                                <TextBlock Text="Event table view (sorted by sequence)" Margin="8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.4"/>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Time" Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding TrajectoryVM.SelectedSession.Steps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Action}" FontSize="11"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Height="16" CornerRadius="3"
                                                        Background="{DynamicResource AccentBrush}"
                                                        HorizontalAlignment="Left"
                                                        Width="100"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DurationMs, StringFormat={}{0}ms}"
                                                           FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" CornerRadius="24"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24"
                        Visibility="{Binding TrajectoryVM.HasSelection, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Selecione uma trajectory" FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
