<UserControl x:Class="KrnlAI.Desktop.App.Controls.MultimodalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <TextBlock Text="Multimodal" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Busca e ingestão multimodal."
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,18"/>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Ingestão" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBox x:Name="IngestInput" Height="80" AcceptsReturn="True"
                             TextWrapping="Wrap" FontSize="13"/>
                    <Button Content="Ingerir" Height="36" Width="120" Margin="0,8,0,0"
                            Click="OnIngest"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Busca" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchInput" Height="36" FontSize="13"/>
                        <Button Grid.Column="1" Content="Buscar" Height="36" Width="100" Margin="8,0,0,0"
                                Click="OnSearch"/>
                    </Grid>
                    <TextBlock x:Name="StatusText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                    <DataGrid x:Name="SearchResultsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Height="200" Margin="0,8,0,0" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="200"/>
                            <DataGridTextColumn Header="Modalidade" Binding="{Binding Modality}" Width="100"/>
                            <DataGridTextColumn Header="Score" Binding="{Binding ScorePercent}" Width="80"/>
                            <DataGridTextColumn Header="Conteúdo" Binding="{Binding Content}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
