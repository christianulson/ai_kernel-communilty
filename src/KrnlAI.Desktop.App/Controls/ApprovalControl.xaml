<UserControl x:Class="KrnlAI.Desktop.App.Controls.ApprovalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <Grid>
            <StackPanel>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{loc:Loc approval_title}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{loc:Loc approval_subtitle}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding ApprovalVM.LoadCommand}" Style="{StaticResource GhostButton}" Padding="16,10">
                        <TextBlock Text="{loc:Loc refresh}"/>
                    </Button>
                </Grid>

                <!-- Loading -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24"
                        Visibility="{Binding ApprovalVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="{loc:Loc loading}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Error -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24"
                        Visibility="{Binding ApprovalVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="{Binding ApprovalVM.ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Empty -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24"
                        Visibility="{Binding ApprovalVM.HasNoData, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="{loc:Loc approval_empty}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Approval list -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24"
                        Visibility="{Binding ApprovalVM.HasData, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc approval_pending_list}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding ApprovalVM.Approvals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,8">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Description}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                                        <Run Text="{loc:Loc approval_type}" FontWeight="SemiBold"/>
                                                        <Run Text="{Binding ActionType}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{loc:Loc approval_risk}"/>
                                                        <Run Text="{Binding RiskScore, StringFormat={}{0:P0}}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="12" Padding="8,4" Background="{DynamicResource WarningBrush}" Opacity="0.8">
                                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="{loc:Loc approval_requested_by}"/>
                                                <Run Text="{Binding RequestedBy, TargetNullValue=—}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding CreatedAt, StringFormat={}{0:g}}"/>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                                                <Button Command="{Binding DataContext.ApprovalVM.ApproveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding RequestId}"
                                                        Style="{StaticResource SmallButton}" Padding="12,6" Margin="0,0,8,0">
                                                    <TextBlock Text="{loc:Loc approval_approve}"/>
                                                </Button>
                                                <Button Command="{Binding DataContext.ApprovalVM.RejectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding RequestId}"
                                                        Style="{StaticResource DangerSmallButton}">
                                                    <TextBlock Text="{loc:Loc approval_reject}"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
