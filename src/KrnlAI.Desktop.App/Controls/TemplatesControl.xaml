<UserControl x:Class="KrnlAI.Desktop.App.Controls.TemplatesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Templates" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Gerencie templates de prompt reutilizáveis." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding TemplatesVM.LoadTemplatesCommand}" Style="{StaticResource GhostButton}" Padding="12,8">Atualizar</Button>
            </Grid>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding TemplatesVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding TemplatesVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                    <Button Grid.Column="1" Command="{Binding TemplatesVM.ClearErrorCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Novo Template" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding TemplatesVM.NewTemplateName}" Height="36" FontSize="13" ToolTip="Nome do template"/>
                        <TextBox Grid.Column="1" Text="{Binding TemplatesVM.NewTemplateCategory}" Height="36" FontSize="13" Margin="8,0,0,0" ToolTip="Categoria"/>
                    </Grid>
                    <TextBox Text="{Binding TemplatesVM.NewTemplateDescription}" Height="36" FontSize="13" Margin="0,0,0,8" ToolTip="Descrição"/>
                    <TextBox Text="{Binding TemplatesVM.NewTemplateContent}" Height="80" AcceptsReturn="True" FontSize="13" Margin="0,0,0,8" ToolTip="Conteúdo do template"/>
                    <Button Command="{Binding TemplatesVM.CreateTemplateCommand}" Style="{StaticResource PrimaryButton}" Height="36" Width="120"
                            IsEnabled="{Binding TemplatesVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">Salvar</Button>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding TemplatesVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,20">
                    <TextBlock Text="⏳" FontSize="18" Margin="0,0,12,0"/>
                    <TextBlock Text="Carregando..." Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0" MinWidth="120">
                    <TextBlock Text="Categorias" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding TemplatesVM.Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Padding="8,4" Margin="0,0,0,4"
                                        Command="{Binding DataContext.TemplatesVM.FilterByCategoryCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <Border Grid.Column="1" Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Templates" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding TemplatesVM.FilteredTemplates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14" CornerRadius="16" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                                                    <Border Padding="4,2" CornerRadius="6" Background="#1838BDF8">
                                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="▶ Renderizar" Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.TemplatesVM.RenderTemplateCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding Id}" Style="{StaticResource SmallButton}"/>
                                            <Button Grid.Column="2" Content="✕" Padding="6,4" FontSize="10"
                                                    Command="{Binding DataContext.TemplatesVM.DeleteTemplateCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding Id}" Style="{StaticResource DangerSmallButton}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,16,0,0"
                    Visibility="{Binding TemplatesVM.RenderedContent, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Preview Renderizado" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Button Grid.Column="1" Command="{Binding TemplatesVM.ClearRenderedContentCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                    </Grid>
                    <Border Padding="12" CornerRadius="12" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding TemplatesVM.RenderedContent}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
