<UserControl x:Class="KrnlAI.Desktop.App.Controls.TemplatesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <TextBlock Text="Templates" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Salve prompts reutilizáveis para tarefas frequentes." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,18"/>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Novo Template" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBox Text="{Binding TemplatesVM.TemplateName}" Height="36" FontSize="13" Margin="0,0,0,8" ToolTip="Nome"/>
                    <TextBox Text="{Binding TemplatesVM.TemplateDescription}" Height="36" FontSize="13" Margin="0,0,0,8" ToolTip="Descrição"/>
                    <TextBox Text="{Binding TemplatesVM.TemplateContent}" Height="80" AcceptsReturn="True" FontSize="13" Margin="0,0,0,8" ToolTip="Conteúdo do template"/>
                    <Button Command="{Binding TemplatesVM.SaveCommand}" Style="{StaticResource PrimaryButton}" Height="36" Width="120" Content="Salvar"/>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding TemplatesVM.Templates}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,6">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Inserir" Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                        Command="{Binding DataContext.TemplatesVM.InsertCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding Id}" Style="{StaticResource SmallButton}"/>
                                <Button Grid.Column="2" Content="✕" Padding="6,4" FontSize="10"
                                        Command="{Binding DataContext.TemplatesVM.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding Id}" Style="{StaticResource DangerSmallButton}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
