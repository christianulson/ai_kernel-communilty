<UserControl x:Class="KrnlAI.Desktop.App.Controls.PeerRankingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1240">
            <TextBlock Text="Peer Ranking" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="Acompanhe a reputação dos peers, ajuste os pesos e reforce a recomputação."
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,18"/>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Filtro" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding PeerRankingVM.FilterText, UpdateSourceTrigger=PropertyChanged}" Height="38"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Tier" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding PeerRankingVM.AvailableTiers}"
                                      SelectedItem="{Binding PeerRankingVM.SelectedTierFilter}"
                                      Height="38"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="Estratégia" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding PeerRankingVM.AvailableStrategies}"
                                      SelectedItem="{Binding PeerRankingVM.SelectedStrategy}"
                                      Height="38"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="Atualizar" Height="38" Margin="0,0,8,0" Command="{Binding PeerRankingVM.RefreshCommand}"/>
                            <Button Content="Recomputar" Height="38" Command="{Binding PeerRankingVM.RecomputeCommand}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding PeerRankingVM.StatusMessage}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding PeerRankingVM.ErrorMessage}" FontSize="11"
                               Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Pesos do ranking" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Ajuste os sinais usados no score composto."
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Salvar pesos" Width="120" Height="36" Margin="0,0,8,0"
                                    Command="{Binding PeerRankingVM.SaveWeightsCommand}"/>
                            <Button Content="Salvar estratégia" Width="140" Height="36"
                                    Command="{Binding PeerRankingVM.SaveStrategyCommand}"/>
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="2" Rows="3" Margin="0,0,0,4">
                        <StackPanel Margin="0,0,16,16">
                            <TextBlock Text="Success rate" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding PeerRankingVM.SuccessRateWeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,16">
                            <TextBlock Text="Latency" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding PeerRankingVM.LatencyWeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,16">
                            <TextBlock Text="Availability" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding PeerRankingVM.AvailabilityWeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,16">
                            <TextBlock Text="Tenure" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding PeerRankingVM.TenureWeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,16">
                            <TextBlock Text="Capacity" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding PeerRankingVM.CapacityWeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,16">
                            <TextBlock Text="Catalog" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding PeerRankingVM.CatalogWeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Peers ranqueados" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding PeerRankingVM.FilteredPeers}"
                              SelectedItem="{Binding PeerRankingVM.SelectedPeer}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              SelectionChanged="OnPeerSelectionChanged"
                              Height="360" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Node" Binding="{Binding NodeId}" Width="180"/>
                            <DataGridTextColumn Header="Tier" Binding="{Binding Tier}" Width="100"/>
                            <DataGridTextColumn Header="Score" Binding="{Binding OverallScore, StringFormat=F1}" Width="90"/>
                            <DataGridTextColumn Header="Success" Binding="{Binding SuccessRateScore, StringFormat=F1}" Width="90"/>
                            <DataGridTextColumn Header="Latency" Binding="{Binding LatencyScore, StringFormat=F1}" Width="90"/>
                            <DataGridTextColumn Header="Uptime %" Binding="{Binding UptimePercentage, StringFormat=F1}" Width="90"/>
                            <DataGridTextColumn Header="Jobs" Binding="{Binding TotalJobsExecuted}" Width="70"/>
                            <DataGridTextColumn Header="Fails" Binding="{Binding TotalJobsFailed}" Width="70"/>
                            <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen, StringFormat=dd/MM HH:mm}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Histórico do peer selecionado" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding PeerRankingVM.History}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource PanelSoftBrush}" CornerRadius="14"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                                <Run Text="{Binding EventType}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding OverallScore, StringFormat=Score: {0:F1}}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Tier, StringFormat=Tier: {0}}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="{Binding Delta, StringFormat=Delta: {0:+0.0;-0.0;0.0}}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Reason, StringFormat=Motivo: {0}}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Timestamp, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding NodeId}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
