<UserControl x:Class="KrnlAI.Desktop.App.Controls.EpisodicMemoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="🧠 Memória Episódica" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Busque episódios passados e explore o histórico de execução." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,20"/>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding EpisodicMemoryVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding EpisodicMemoryVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                    <Button Grid.Column="1" Command="{Binding EpisodicMemoryVM.ClearErrorCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding EpisodicMemoryVM.SearchQuery, UpdateSourceTrigger=PropertyChanged}" Height="44" FontSize="14"
                             ToolTip="Buscar episódios por descrição, objetivo ou resultado...">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding EpisodicMemoryVM.SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Command="{Binding EpisodicMemoryVM.SearchCommand}" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Height="44" MinWidth="100"
                            IsEnabled="{Binding EpisodicMemoryVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">Buscar</Button>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24" Margin="0,0,0,16"
                    Visibility="{Binding EpisodicMemoryVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,20">
                    <TextBlock Text="⏳" FontSize="18" Margin="0,0,12,0"/>
                    <TextBlock Text="Buscando..." Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding EpisodicMemoryVM.Results}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14" CornerRadius="16" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.EpisodicMemoryVM.SelectEpisodeCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="12" Background="{DynamicResource PanelSoftBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Similarity, StringFormat={}{0:P0}}" FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Goal}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Border Padding="6,2" CornerRadius="6" Background="{DynamicResource PanelSoftBrush}" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"
                                               TextWrapping="Wrap" MaxHeight="40"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:g}}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
