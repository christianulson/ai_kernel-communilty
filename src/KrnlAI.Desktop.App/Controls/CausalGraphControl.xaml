<UserControl x:Class="KrnlAI.Desktop.App.Controls.CausalGraphControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{loc:Loc nav_causal}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Visualização de relações causais." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding CausalVM.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding CausalVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
            </Border>

            <!-- Query -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox Text="{Binding CausalVM.Query, UpdateSourceTrigger=PropertyChanged}" Height="44"
                             AutomationProperties.AutomationId="CausalQueryBox">
                        <TextBox.InputBindings><KeyBinding Key="Return" Command="{Binding CausalVM.SearchCommand}"/></TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Command="{Binding CausalVM.SearchCommand}" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Height="44" MinWidth="120"
                            Content="{Binding CausalVM.SearchButtonText}"/>
                </Grid>
            </Border>

            <!-- Graph Visual -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding CausalVM.ResultData, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Grafo Causal" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <ItemsControl ItemsSource="{Binding CausalVM.ResultData.Nodes}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="140" Height="80" Margin="6" CornerRadius="12" Padding="8"
                                            Background="#2E38BDF8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Type}" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Edges List -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding CausalVM.ResultData, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Relações" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding CausalVM.ResultData.Edges}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" CornerRadius="8" Background="#14FFFFFF" Margin="0,0,0,4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="→" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"><Run Text="{Binding SourceId}"/> → <Run Text="{Binding TargetId}"/></TextBlock>
                                            <TextBlock Text="{Binding Label}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Predict -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox Text="{Binding CausalVM.PredictAction, UpdateSourceTrigger=PropertyChanged}" Height="44"
                             ToolTip="Ação para predizer o resultado">
                        <TextBox.InputBindings><KeyBinding Key="Return" Command="{Binding CausalVM.PredictCommand}"/></TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Command="{Binding CausalVM.PredictCommand}" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Height="44" MinWidth="120"
                            Content="{Binding CausalVM.PredictButtonText}"/>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24"
                    Visibility="{Binding CausalVM.PredictionResult, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Resultado da Predição" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Border Padding="14,10" CornerRadius="12" Background="#14FFFFFF" Margin="0,0,0,8">
                        <TextBlock Text="{Binding CausalVM.PredictionResult.Outcome}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                    <Border Padding="14,10" CornerRadius="12" Background="#14FFFFFF">
                        <StackPanel>
                            <TextBlock Text="{Binding CausalVM.PredictionResult.Probability, StringFormat={}{0:P1}}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="Probabilidade" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            <ProgressBar Value="{Binding CausalVM.PredictionResult.Probability}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
