<UserControl x:Class="KrnlAI.Desktop.App.Controls.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KrnlAI.Desktop.App.ViewModels"
             xmlns:models="clr-namespace:KrnlAI.Desktop.Core.Models"
             Loaded="OnLoaded" Unloaded="OnUnloaded">
    <UserControl.Resources>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="28,28,28,0">
            <TextBlock Text="Terminal" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Execute comandos via SignalR" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
        </StackPanel>

        <!-- Output -->
        <Border Grid.Row="1" Background="#0A000000" CornerRadius="12" Padding="16" Margin="28,0,28,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <ScrollViewer x:Name="OutputScrollViewer" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Output}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:TerminalOutput">
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Type, StringFormat='[{0}]'}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,6,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Text}"
                                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="error">
                                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Error -->
        <Border Grid.Row="2" Margin="28,0,28,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                Background="#2EFF6B6B" CornerRadius="8" Padding="12,8">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B" FontSize="11"/>
        </Border>

        <!-- Input Bar -->
        <Border Grid.Row="3" Background="{DynamicResource PanelBrush}" CornerRadius="24"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="20" Margin="28,0,28,28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="$" FontFamily="Consolas" FontSize="14"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>

                <TextBox Grid.Column="1" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                         Height="36" FontFamily="Consolas" FontSize="13"
                         Background="Transparent" BorderThickness="0"
                         ToolTip="Type a command and press Enter">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding ExecuteCommand}"/>
                        <KeyBinding Key="Up" Command="{Binding NavigateHistoryUpCommand}"/>
                        <KeyBinding Key="Down" Command="{Binding NavigateHistoryDownCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="2" Command="{Binding CancelCommand}"
                        Style="{StaticResource DangerButton}" Height="36" MinWidth="80"
                        Margin="8,0,0,0" Content="Cancel"
                        Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Grid.Column="3" Command="{Binding ClearOutputCommand}"
                        Style="{StaticResource GhostButton}" Height="36" MinWidth="80"
                        Margin="8,0,0,0" Content="Clear"/>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="28,6,28,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionStatus}" Value="Connected">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionStatus}" Value="Connecting">
                                        <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionStatus}" Value="Reconnecting">
                                        <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <TextBlock Grid.Column="1" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Right"
                           Text="{Binding OutputLineCount}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

