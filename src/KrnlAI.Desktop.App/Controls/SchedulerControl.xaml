<UserControl x:Class="KrnlAI.Desktop.App.Controls.SchedulerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Agendamento" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Tarefas agendadas do agente." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding SchedulerVM.LoadCommand}" Style="{StaticResource GhostButton}" Padding="16,10"><TextBlock Text="Atualizar"/></Button>
            </Grid>
            <TextBlock Text="{Binding SchedulerVM.ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" FontSize="13"
                       Visibility="{Binding SchedulerVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <ItemsControl ItemsSource="{Binding SchedulerVM.Tasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="{Binding CronExpression, Mode=OneWay}"/> · <Run Text="{Binding Action, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="1" Padding="8,4" CornerRadius="8" BorderThickness="1" VerticalAlignment="Center"
                                        BorderBrush="{DynamicResource BorderBrush}">
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Ativo"/><Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                <Style.Triggers><DataTrigger Binding="{Binding Enabled}" Value="False"><Setter Property="Text" Value="Inativo"/><Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/></DataTrigger></Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
