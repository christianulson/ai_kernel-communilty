<UserControl x:Class="KrnlAI.Desktop.App.Controls.PieControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="🔗 PIE (Probabilistic Inference Engine)" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Inferência probabilística, cadeias lógicas e coerência." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,20"/>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding PieVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding PieVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                    <Button Grid.Column="1" Command="{Binding PieVM.ClearErrorCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🧠 Inferência" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Premissa" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding PieVM.Premise, UpdateSourceTrigger=PropertyChanged}" Height="44" FontSize="14" Margin="0,0,0,12"/>
                    <TextBlock Text="Contexto (opcional)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding PieVM.Context, UpdateSourceTrigger=PropertyChanged}" Height="44" FontSize="14" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding PieVM.InferCommand}" Style="{StaticResource PrimaryButton}" Height="44" MinWidth="120"
                                IsEnabled="{Binding PieVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">Inferir</Button>
                    </StackPanel>
                    <Border Padding="16" CornerRadius="16" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,16,0,0"
                            Visibility="{Binding PieVM.Conclusion, Converter={StaticResource StringToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Conclusão" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding PieVM.Conclusion}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run Text="Confiança: "/><Run Text="{Binding PieVM.Confidence, StringFormat={}{0:P1}}" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="⛓️ Cadeia Lógica" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Premissa inicial" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding PieVM.ChainPremise, UpdateSourceTrigger=PropertyChanged}" Height="44" FontSize="14" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Passos" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding PieVM.ChainSteps, UpdateSourceTrigger=PropertyChanged}" Height="44" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Contexto" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding PieVM.ChainContext, UpdateSourceTrigger=PropertyChanged}" Height="44" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                    <Button Command="{Binding PieVM.ChainCommand}" Style="{StaticResource PrimaryButton}" Height="44" MinWidth="120" HorizontalAlignment="Right"
                            IsEnabled="{Binding PieVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">Encadear</Button>
                    <ItemsControl ItemsSource="{Binding PieVM.ChainResults}" Margin="0,16,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" CornerRadius="12" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Padding="6,3" CornerRadius="8" Background="#1838BDF8">
                                            <TextBlock Text="{Binding Step, StringFormat=Passo {0}}" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0">
                                            <TextBlock Text="{Binding Premise}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Conclusion}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Confidence, StringFormat={}{0:P1}}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="📖 Termos" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <Button Command="{Binding PieVM.LoadTermsCommand}" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,0,0,8">Carregar</Button>
                        <ItemsControl ItemsSource="{Binding PieVM.Terms}" MaxHeight="300">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" CornerRadius="10" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding OccurrenceCount, StringFormat={}{0}x}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="📊 Coerência" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <Button Command="{Binding PieVM.LoadCoherenceCommand}" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,0,0,8">Auditar</Button>
                        <Border Padding="16" CornerRadius="22" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,12"
                                Visibility="{Binding PieVM.Coherence, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding PieVM.Coherence.OverallCoherence, TargetNullValue=—, StringFormat={}{0:P1}}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Coerência geral" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding PieVM.Coherence.Entries}" MaxHeight="200">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" CornerRadius="8" Background="#14FFFFFF" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Statement}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CoherenceScore, StringFormat={}{0:P0}}" FontSize="10" Foreground="{DynamicResource PrimaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
