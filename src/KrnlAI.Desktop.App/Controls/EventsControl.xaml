<UserControl x:Class="KrnlAI.Desktop.App.Controls.EventsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="📋 Eventos" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Registro de eventos cognitivos e do sistema." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding EventsVM.LoadRecentCommand}" Style="{StaticResource PrimaryButton}" Height="44" MinWidth="120"
                        IsEnabled="{Binding EventsVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Recarregar"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding EventsVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding EventsVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                    <Button Grid.Column="1" Command="{Binding EventsVM.ClearErrorCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Eventos Recentes" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding EventsVM.FilteredEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" CornerRadius="12" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,6" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.EventsVM.LoadRecentCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Padding="4,2" CornerRadius="6" Background="#1838BDF8">
                                                <TextBlock Text="{Binding Type}" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0">
                                                <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Source}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat=HH:mm:ss}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🔍 Detalhe" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <Border Padding="16" CornerRadius="16" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding EventsVM.SelectedEvent.EventId, TargetNullValue=Nenhum evento selecionado}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding EventsVM.SelectedEvent.Description}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                                <TextBlock Text="{Binding EventsVM.SelectedEvent.Type}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding EventsVM.SelectedEvent.Timestamp, StringFormat=g}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="📌 Eventos por Momento" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding EventsVM.MomentId, UpdateSourceTrigger=PropertyChanged}" Height="44" FontSize="14"
                                 ToolTip="ID do momento">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding EventsVM.LoadByMomentCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding EventsVM.LoadByMomentCommand}" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Height="44" MinWidth="100"
                                IsEnabled="{Binding EventsVM.IsLoading, Converter={StaticResource InverseBoolConverter}}">Buscar</Button>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
