<UserControl x:Class="KrnlAI.Desktop.App.Controls.CognitiveCycleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Ciclo Cognitivo" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding CognitiveCycleVM.SelectedCycleId, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="32" Padding="8" Margin="0,0,8,0"
                         Background="{DynamicResource PanelBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBox.ToolTip>ID do ciclo (opcional — deixe vazio para conectar ao stream ativo)</TextBox.ToolTip>
                </TextBox>
                <Button Grid.Column="1" Command="{Binding CognitiveCycleVM.ConnectCommand}" Padding="12,6" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CognitiveCycleVM.IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding CognitiveCycleVM.StreamState}"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Command="{Binding CognitiveCycleVM.DisconnectCommand}" Padding="12,6"
                        Style="{StaticResource GhostButton}" Content="Desconectar"/>
            </Grid>
            <Border Visibility="{Binding CognitiveCycleVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="8" Margin="0,8,0,0" CornerRadius="8" Background="#20EF4444">
                <TextBlock Text="{Binding CognitiveCycleVM.ErrorMessage}" Foreground="{DynamicResource ErrorBrush}"/>
            </Border>
        </StackPanel>
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center">
                    <Run Text="{Binding CognitiveCycleVM.Events.Count}"/><Run Text=" eventos"/>
                </TextBlock>
                <Button Command="{Binding CognitiveCycleVM.ClearEventsCommand}" Content="Limpar"
                        Style="{StaticResource GhostButton}" FontSize="11" Padding="8,4" Margin="8,0,0,0"/>
            </StackPanel>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding CognitiveCycleVM.Events}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" CornerRadius="8" Margin="0,0,0,6"
                                    Background="{DynamicResource PanelSoftBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,12,0" MinWidth="60">
                                        <TextBlock Text="{Binding StepName}" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text="{Binding Timestamp}" FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Type}" FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Visibility="{Binding Content, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
