<UserControl x:Class="KrnlAI.Desktop.App.Controls.InvestigationsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Investigações" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               AutomationProperties.AutomationId="InvestigationsHeader"/>
                    <TextBlock Text="Casos de investigação do agente."
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding InvestigationsVM.LoadCommand}"
                        Style="{StaticResource GhostButton}" Padding="16,10">
                    <TextBlock Text="Atualizar"/>
                </Button>
            </Grid>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding InvestigationsVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding InvestigationsVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
            </Border>

            <Border Height="40" CornerRadius="12" Background="{DynamicResource PanelBrush}" Margin="0,0,0,8"
                    Visibility="{Binding InvestigationsVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="⏳ Carregando..." FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <ItemsControl ItemsSource="{Binding InvestigationsVM.Investigations}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="16"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Padding="16" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="#2E38BDF8" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="🔍" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0">
                                        <Run Text="{Binding Status, Mode=OneWay}"/> · <Run Text="{Binding CaseId, Mode=OneWay}"/> · <Run Text="{Binding EvidenceCount, Mode=OneWay, StringFormat={}{0} evidências}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
