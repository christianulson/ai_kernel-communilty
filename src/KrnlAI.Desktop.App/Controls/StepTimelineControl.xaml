<UserControl x:Class="KrnlAI.Desktop.App.Controls.StepTimelineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
        <ItemsControl x:Name="EventList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,2" Padding="8,6" CornerRadius="6"
                            Background="{Binding Background}" BorderThickness="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding StepName}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Content}" FontSize="11" Opacity="0.7"
                                           Visibility="{Binding HasContent, Converter={StaticResource BoolToVisibilityConverter}}"
                                           TextTrimming="CharacterEllipsis" MaxHeight="40"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Duration}" FontSize="10" Opacity="0.5" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
