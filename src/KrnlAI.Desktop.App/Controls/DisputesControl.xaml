<UserControl x:Class="KrnlAI.Desktop.App.Controls.DisputesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1240">
            <TextBlock Text="Disputas" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Acompanhe e resolva disputas de pagamento entre peers."
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,18"/>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Disputas abertas" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Selecione uma disputa para ver detalhes."
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Atualizar" Height="36"
                                Command="{Binding DisputesVM.RefreshCommand}"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding DisputesVM.Disputes}"
                              SelectedItem="{Binding DisputesVM.SelectedDispute}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Height="280" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dispute ID" Binding="{Binding DisputeId}" Width="200"/>
                            <DataGridTextColumn Header="Work ID" Binding="{Binding WorkId}" Width="180"/>
                            <DataGridTextColumn Header="Worker" Binding="{Binding WorkerNodeId}" Width="120"/>
                            <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="200"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Abertura" Binding="{Binding OpenedAt, StringFormat=dd/MM HH:mm}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Dispute Detail -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16"
                    Visibility="{Binding DisputesVM.HasSelectedDispute, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Detalhe da disputa" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding DisputesVM.SelectedDispute.DisputeId, StringFormat=ID: {0}}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding DisputesVM.SelectedDispute.Reason, StringFormat=Motivo: {0}}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding DisputesVM.SelectedDispute.Status, StringFormat=Status: {0}}"
                                       FontSize="12" Foreground="{DynamicResource WarningBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="Resolver a favor do worker" Height="36" Margin="0,0,8,0"
                                    Command="{Binding DisputesVM.ResolveForWorkerCommand}"
                                    Background="{DynamicResource SuccessBrush}"/>
                            <Button Content="Resolver a favor do solicitante" Height="36"
                                    Command="{Binding DisputesVM.ResolveForSolicitorCommand}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
