<UserControl x:Class="KrnlAI.Desktop.App.Controls.PlanControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="📋 Plano Atual" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Acompanhe a execução do plano atual." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding PlanVM.LoadPlanCommand}" Style="{StaticResource GhostButton}" Padding="12,8">Atualizar</Button>
            </Grid>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding PlanVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding PlanVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                    <Button Grid.Column="1" Command="{Binding PlanVM.ClearErrorCommand}" Style="{StaticResource SmallButton}" Padding="6" FontSize="10">✕</Button>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24" Margin="0,0,0,16"
                    Visibility="{Binding PlanVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,20">
                    <TextBlock Text="⏳" FontSize="18" Margin="0,0,12,0"/>
                    <TextBlock Text="Carregando plano..." Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding PlanVM.CurrentPlan, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding PlanVM.CurrentPlan.Goal}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding PlanVM.CurrentPlan.Description}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="8" Background="{DynamicResource PanelSoftBrush}" Height="12">
                            <Grid>
                                <Border CornerRadius="8" Background="{DynamicResource PrimaryBrush}" HorizontalAlignment="Left"
                                        Width="{Binding PlanVM.Progress, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=300}" Height="12"/>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <Binding Path="PlanVM.Progress" StringFormat="{}{0:P0}"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                            <TextBlock.Text>
                                <Binding Path="PlanVM.CurrentPlan.CompletedSteps" StringFormat="{}{0} concluídos"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text=" / " FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                            <TextBlock.Text>
                                <Binding Path="PlanVM.CurrentPlan.TotalSteps" StringFormat="{}{0} total"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text=" · " FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding PlanVM.CurrentPlan.Status}" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Passos" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"
                       Visibility="{Binding PlanVM.CurrentPlan, Converter={StaticResource NullToVisibilityConverter}}"/>
            <ItemsControl ItemsSource="{Binding PlanVM.Steps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14" CornerRadius="16" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource PanelSoftBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Index, StringFormat={}{0}}" FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Description}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Padding="8,4" CornerRadius="8" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource PanelSoftBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                    <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
