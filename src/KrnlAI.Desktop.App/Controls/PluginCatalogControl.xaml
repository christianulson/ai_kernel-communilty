<UserControl x:Class="KrnlAI.Desktop.App.Controls.PluginCatalogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <TextBlock Text="Catálogo de Plugins" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Navegue e instale plugins MCP." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,18"/>
            <ItemsControl ItemsSource="{Binding PluginCatalogVM.Plugins}">
                <ItemsControl.ItemTemplate><DataTemplate>
                    <Border Background="{DynamicResource PanelBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,6">
                        <TextBlock Text="{Binding}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                </DataTemplate></ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
