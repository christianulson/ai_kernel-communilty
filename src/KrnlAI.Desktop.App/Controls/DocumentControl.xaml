<UserControl x:Class="KrnlAI.Desktop.App.Controls.DocumentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Documentos" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Documentos ingeridos pelo pipeline RAG" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding DocumentVM.LoadDocumentsCommand}" Style="{StaticResource GhostButton}" Padding="16,10">
                        <TextBlock Text="Atualizar"/>
                    </Button>
                </Grid>
                <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                        Visibility="{Binding DocumentVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding DocumentVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
                </Border>
                <Border Background="{StaticResource PanelBrush}" CornerRadius="24" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="24" Margin="0,0,0,16"
                        Visibility="{Binding DocumentVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,20">
                        <TextBlock Text="Carregando documentos..." Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" CornerRadius="24" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="24"
                        Visibility="{Binding DocumentVM.HasNoData, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="Nenhum documento encontrado" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Envie documentos via API ou web interface." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" CornerRadius="24" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="0">
                    <StackPanel>
                        <Grid Margin="20,16,20,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="80"/><ColumnDefinition Width="100"/><ColumnDefinition Width="80"/><ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Arquivo" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="Formato" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="Status" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="Chunks" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="Criado" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding DocumentVM.DocumentList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="20,8" Margin="0,0,0,2" Background="Transparent" CornerRadius="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/><ColumnDefinition Width="80"/><ColumnDefinition Width="100"/><ColumnDefinition Width="80"/><ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding FileName}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Format}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding ChunkCount}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="24" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="24"
                    Visibility="{Binding DocumentVM.SelectedDocument, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Detalhes" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Grid.Column="1" Content="X" Style="{StaticResource SmallButton}" Command="{Binding DocumentVM.ClearSelectionCommand}" Width="28" Height="28"/>
                    </Grid>
                    <StackPanel>
                        <TextBlock Text="Document ID" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding DocumentVM.SelectedDocument.DocumentId}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Arquivo" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding DocumentVM.SelectedDocument.FileName}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Tamanho" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding DocumentVM.SelectedDocument.FileSize, StringFormat={}{0:N0} bytes}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Formato" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding DocumentVM.SelectedDocument.Format}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Status" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding DocumentVM.SelectedDocument.Status}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Chunks" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding DocumentVM.SelectedDocument.ChunkCount}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Criado" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding DocumentVM.SelectedDocument.CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
