<UserControl x:Class="KrnlAI.Desktop.App.Controls.UserServicesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="🔗 Serviços do Usuário" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Gerencie as integrações e serviços externos vinculados à sua conta." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding LoadCommand}" Style="{StaticResource GhostButton}" Padding="12,8">Atualizar</Button>
            </Grid>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#FFDBE1" FontSize="13"/>
                </Grid>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,20">
                    <TextBlock Text="⏳" FontSize="18" Margin="0,0,12,0"/>
                    <TextBlock Text="Carregando..." Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20">
                <ItemsControl ItemsSource="{Binding Services}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14" CornerRadius="16" Background="#14FFFFFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="12"
                                            Background="{Binding Configured, Converter={StaticResource BoolToColorConverter}}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ServiceType, StringFormat={}{0}}" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ServiceType}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                                            <Border Padding="4,2" CornerRadius="6" Background="#1838BDF8">
                                                <TextBlock FontSize="10" Foreground="{DynamicResource PrimaryBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Não configurado"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Configured}" Value="True">
                                                                    <Setter Property="Text" Value="Configurado"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <Border Padding="4,2" CornerRadius="6" Margin="6,0,0,0" Background="#1822C55E">
                                                <TextBlock FontSize="10" Foreground="#22C55E">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Inativo"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                    <Setter Property="Text" Value="Ativo"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding LastUsedAt, StringFormat=Último uso: {0:dd/MM/yyyy}}" FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                            CommandParameter="{Binding ServiceType}"
                                            Padding="8,4" FontSize="10"
                                            VerticalAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SmallButton}">
                                                <Setter Property="Content" Value="Ativar"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                        <Setter Property="Content" Value="Desativar"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
