<UserControl x:Class="KrnlAI.Desktop.App.Controls.SearchOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#CC000000" Panel.ZIndex="300">
        <Border Width="600" Height="Auto" VerticalAlignment="Start" Margin="0,80,0,0"
                Background="{DynamicResource PanelBrush}" CornerRadius="24"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="24">
            <StackPanel>
                <TextBox x:Name="SearchBox" Height="48" FontSize="18"
                         ToolTip="Pesquisar..." KeyDown="OnSearchKeyDown"
                         AutomationProperties.AutomationId="GlobalSearchBox"/>
                <TextBlock x:Name="ResultsText" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                <ItemsControl x:Name="ResultsList" Margin="0,8,0,0" MaxHeight="400">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,8" CornerRadius="8" Margin="0,2"
                                    Background="{DynamicResource PanelSoftBrush}">
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="13"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Border>
</UserControl>
