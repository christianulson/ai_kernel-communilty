<UserControl x:Class="KrnlAI.Desktop.App.Controls.ObjectivesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Objetivos" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               AutomationProperties.AutomationId="ObjectivesHeader"/>
                    <TextBlock Text="Metas e progresso do agente."
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding ObjectivesVM.LoadCommand}"
                        Style="{StaticResource GhostButton}" Padding="16,10">
                    <TextBlock Text="Atualizar"/>
                </Button>
            </Grid>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding ObjectivesVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding ObjectivesVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
            </Border>

            <Border Height="40" CornerRadius="12" Background="{DynamicResource PanelBrush}" Margin="0,0,0,8"
                    Visibility="{Binding ObjectivesVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="⏳ Carregando..." FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <ItemsControl ItemsSource="{Binding ObjectivesVM.Objectives}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="16"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Padding="16" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Description}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0">
                                        <Run Text="{Binding Status, Mode=OneWay}"/> · <Run Text="{Binding Progress, Mode=OneWay, StringFormat={}{0:P1}}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="1" Width="80" Height="8" CornerRadius="4" Background="#12FFFFFF" VerticalAlignment="Center">
                                    <Border CornerRadius="4" Background="{DynamicResource AccentBrush}"
                                            HorizontalAlignment="Left"
                                            Width="{Binding Progress, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=80}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
