<Window x:Class="KrnlAI.Desktop.App.Controls.ConfirmModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:KrnlAI.Desktop.App.Converters"
        Title="{loc:Loc confirm_title}" Height="200" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="{DynamicResource BackgroundBrush}"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
        <TextBlock x:Name="MessageText" Grid.Row="1" FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CancelButton" Content="{loc:Loc cancel}"
                    Style="{StaticResource GhostButton}" Padding="16,8"
                    MinWidth="80" Margin="0,0,8,0" IsCancel="True"/>
            <Button x:Name="ConfirmButton" Content="{loc:Loc confirm}"
                    Style="{StaticResource DangerButton}" Padding="16,8"
                    MinWidth="80" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
