<UserControl x:Class="KrnlAI.Desktop.App.Controls.SidecarConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1240">
            <TextBlock Text="Sidecar" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Configuração do runtime local Sidecar — modo community e enterprise."
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,18"/>

            <!-- Mode Indicator -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="12" Height="12" Fill="{DynamicResource SuccessBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding SidecarVM.ModeLabel}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding SidecarVM.ModeDescription}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Testar conexão" Height="36" Width="140"
                            Command="{Binding SidecarVM.TestConnectionCommand}"/>
                </Grid>
            </Border>

            <!-- Enterprise Config -->
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Configuração Enterprise" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Auth Endpoint" Grid.Row="0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Height="36" Margin="0,0,0,8"
                                 Text="{Binding SidecarVM.AuthEndpoint, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Gateway Endpoint" Grid.Row="1" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Height="36" Margin="0,0,0,8"
                                 Text="{Binding SidecarVM.GatewayEndpoint, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="API Key" Grid.Row="2" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <PasswordBox Grid.Row="2" Grid.Column="1" Height="36" Margin="0,0,0,8"
                                     PasswordChar="*"
                                     PasswordChanged="OnPasswordChanged"/>

                        <TextBlock Text="Tenant ID" Grid.Row="3" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Height="36" Margin="0,0,0,8"
                                 Text="{Binding SidecarVM.TenantId, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Salvar configuração" Height="36" Width="180" Margin="0,0,8,0"
                                    Command="{Binding SidecarVM.SaveConfigCommand}"/>
                            <Button Content="Resetar para community" Height="36" Width="200"
                                    Command="{Binding SidecarVM.ResetToCommunityCommand}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding SidecarVM.StatusMessage}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding SidecarVM.ErrorMessage}" FontSize="11"
                               Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
