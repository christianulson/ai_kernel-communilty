<UserControl x:Class="KrnlAI.Desktop.App.Controls.KanbanControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:KrnlAI.Desktop.App.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/KanbanStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Kanban Board" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,0">
                        <Button Content="Refresh" Command="{Binding LoadCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    </StackPanel>
                </Grid>

                <!-- Filters -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                            <TextBlock Text="Days:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                             <TextBox Text="{Binding DaysBack, UpdateSourceTrigger=LostFocus}" Width="60"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                            <TextBlock Text="Domain:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                             <TextBox Text="{Binding SelectedDomain, UpdateSourceTrigger=LostFocus}" Width="120"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                            <TextBlock Text="Min Priority:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                             <TextBox Text="{Binding MinPriority, UpdateSourceTrigger=LostFocus}" Width="60"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                             <TextBox Text="{Binding SearchText, UpdateSourceTrigger=LostFocus}" Width="150"/>
                            <Button Content="Go" Command="{Binding SearchCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorBrush}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                           Margin="0,0,0,16"/>

                <!-- Loading -->
                <TextBlock Text="Loading..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                <!-- Columns -->
                <ItemsControl ItemsSource="{Binding Columns}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource KanbanColumnStyle}">
                                <StackPanel>
                                    <!-- Column Header -->
                                    <Grid Margin="16,16,16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Border Grid.Column="1" Background="{DynamicResource AccentBrush}"
                                                CornerRadius="10" Padding="8,2" MinWidth="24" Height="22">
                                            <TextBlock Text="{Binding TotalCount}"
                                                       FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"/>
                                        </Border>
                                    </Grid>
                                    <!-- Cards -->
                                    <ItemsControl ItemsSource="{Binding Cards}" Margin="12,0,12,12">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource KanbanCardStyle}">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Description}"
                                                                       Style="{StaticResource KanbanCardTitleStyle}"/>
                                                            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                                    Background="{DynamicResource AccentBrush}">
                                                                <TextBlock Text="{Binding Priority, StringFormat='P{0}'}"
                                                                           FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                        </Grid>
                                                        <ProgressBar Value="{Binding Progress}" Maximum="1"
                                                                     Height="4" Margin="0,8,0,0"
                                                                     Foreground="{DynamicResource SuccessBrush}"
                                                                     Background="{DynamicResource BorderBrush}"/>
                                                         <TextBlock Style="{StaticResource KanbanCardMetaStyle}">
                                                             <TextBlock.Text>
                                                                 <Binding Path="Progress" StringFormat="Progress: {0:P0}"/>
                                                             </TextBlock.Text>
                                                         </TextBlock>
                                                        <TextBlock Text="{Binding Deadline, StringFormat='📅 {0:yyyy-MM-dd}'}"
                                                                   Style="{StaticResource KanbanCardMetaStyle}"
                                                                   Visibility="{Binding Deadline, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
