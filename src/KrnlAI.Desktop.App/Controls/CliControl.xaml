<UserControl x:Class="KrnlAI.Desktop.App.Controls.CliControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <TextBlock Text="Terminal CLI" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Execute comandos do KrnlAI.Cli diretamente do Desktop." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,18"/>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Comandos disponíveis" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding CliVM.AvailableCommands}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="2" FontFamily="{StaticResource FontMono}"/></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource PanelBrush}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox Text="{Binding CliVM.Command, UpdateSourceTrigger=PropertyChanged}" Height="44" FontFamily="{StaticResource FontMono}" FontSize="13"
                             ToolTip="Digite um comando (ex: health, status, memory search test)">
                        <TextBox.InputBindings><KeyBinding Key="Return" Command="{Binding CliVM.ExecuteCommand}"/></TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Command="{Binding CliVM.ExecuteCommand}" Style="{StaticResource PrimaryButton}" Height="44" MinWidth="100" Margin="8,0,0,0" Content="Executar"/>
                </Grid>
            </Border>

            <TextBlock Text="{Binding CliVM.StatusMessage}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <Border Background="#0A000000" CornerRadius="12" Padding="16" MinHeight="100" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                    <TextBlock Text="{Binding CliVM.Output}" FontFamily="{StaticResource FontMono}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
            <Button Command="{Binding CliVM.ClearOutputCommand}" Style="{StaticResource GhostButton}" Height="32" Width="100" Margin="0,8,0,0" Content="Limpar"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
