<UserControl x:Class="KrnlAI.Desktop.App.Controls.AdminUsersControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Admin - Usuários" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Gerenciamento de usuários."
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding AdminUsersVM.LoadCommand}"
                        Style="{StaticResource GhostButton}" Padding="16,10">
                    <TextBlock Text="Atualizar"/>
                </Button>
            </Grid>

            <TextBlock Text="{Binding AdminUsersVM.StatusMessage}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Ativar" Width="100" Height="36" Margin="0,0,8,0"
                        IsEnabled="{Binding AdminUsersVM.HasSelection}"
                        Click="OnActivateClick"/>
                <Button Content="Suspender" Width="100" Height="36"
                        Style="{StaticResource DangerButton}"
                        IsEnabled="{Binding AdminUsersVM.HasSelection}"
                        Click="OnSuspendClick"/>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding AdminUsersVM.Users}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="12"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Padding="12" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                        <Run Text="{Binding Email}"/> · <Run Text="{Binding Role}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="1" VerticalAlignment="Center" Padding="8,4" CornerRadius="8"
                                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Ativo"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Text" Value="Suspenso"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
