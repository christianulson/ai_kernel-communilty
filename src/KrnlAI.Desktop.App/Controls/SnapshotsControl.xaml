<UserControl x:Class="KrnlAI.Desktop.App.Controls.SnapshotsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <ScrollViewer Padding="28" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Snapshots" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               AutomationProperties.AutomationId="SnapshotsHeader"/>
                    <TextBlock Text="Snapshots são criados automaticamente."
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding SnapshotsVM.CreateSnapshotCommand}"
                        Style="{StaticResource PrimaryButton}" Padding="16,10" Margin="0,0,8,0">
                    <TextBlock Text="📸 Criar Snapshot"/>
                </Button>
                <Button Grid.Column="2" Command="{Binding SnapshotsVM.LoadCommand}"
                        Style="{StaticResource GhostButton}" Padding="16,10">
                    <TextBlock Text="Atualizar"/>
                </Button>
            </Grid>

            <TextBlock Text="{Binding SnapshotsVM.StatusMessage}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

            <Border Background="#18FB7185" BorderBrush="#3CFB7185" BorderThickness="1" CornerRadius="16" Padding="14,10" Margin="0,0,0,12"
                    Visibility="{Binding SnapshotsVM.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding SnapshotsVM.ErrorMessage}" Foreground="#FFDBE1" FontSize="13"/>
            </Border>

            <Border Height="40" CornerRadius="12" Background="{DynamicResource PanelBrush}" Margin="0,0,0,8"
                    Visibility="{Binding SnapshotsVM.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="⏳ Carregando..." FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <ItemsControl ItemsSource="{Binding SnapshotsVM.Snapshots}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="16"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Padding="16" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="#2E14B8A6" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="📸" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Size, StringFormat={}{0} bytes}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
