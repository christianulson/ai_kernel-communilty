{
  "Sidecar": {
    "Auth": {
      "Token": ""
    },
    "RateLimiting": {
      "GlobalPermitLimit": 60,
      "WindowSeconds": 10,
      "AgentRunPermitLimit": 10,
      "MemoryReadPermitLimit": 30
    },
    "Cors": {
      "AllowedOrigins": []
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AIKernel": "Information"
    }
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 1048576
    }
  }
}
